<div class="flex items-center justify-center min-h-screen bg-gray-100 dark:bg-gray-900 px-4">
  <div class="w-full max-w-md bg-white dark:bg-gray-800 rounded-xl shadow-lg
              border border-gray-200 dark:border-gray-700 p-6">

    <h2 class="text-2xl font-bold text-center text-blue-600 dark:text-blue-400 mb-6">
      Login to TurboBlog
    </h2>

    <%= form_for(resource, as: resource_name, url: session_path(resource_name),
        html: { class: "space-y-4" }) do |f| %>

      <div>
        <%= f.label :email, class: "block mb-1 text-sm font-medium text-gray-700 dark:text-gray-300" %>
        <%= f.email_field :email, autofocus: true,
            class: "w-full px-3 py-2 rounded-lg outline-none
                    border border-gray-300 dark:border-gray-600
                    bg-white dark:bg-gray-700
                    text-gray-900 dark:text-white
                    placeholder-gray-400 dark:placeholder-gray-500
                    focus:ring-2 focus:ring-blue-500" %>
      </div>

      <div>
        <%= f.label :password, class: "block mb-1 text-sm font-medium text-gray-700 dark:text-gray-300" %>
        <%= f.password_field :password,
            class: "w-full px-3 py-2 rounded-lg outline-none
                    border border-gray-300 dark:border-gray-600
                    bg-white dark:bg-gray-700
                    text-gray-900 dark:text-white
                    focus:ring-2 focus:ring-blue-500" %>
      </div>

      <div class="flex items-center">
        <%= f.check_box :remember_me, class: "mr-2 accent-blue-600" %>
        <%= f.label :remember_me, class: "text-sm text-gray-600 dark:text-gray-400" %>
      </div>

      <%= f.submit "Log in",
          class: "w-full bg-blue-600 hover:bg-blue-700 text-white py-2
                  rounded-lg font-medium transition cursor-pointer" %>
    <% end %>

    <div class="mt-4 text-center text-sm text-gray-600 dark:text-gray-400">
      <%= link_to "Sign up", new_registration_path(resource_name),
          class: "text-blue-600 dark:text-blue-400 hover:underline" %>
      |
      <%= link_to "Forgot password?", new_password_path(resource_name),
          class: "text-blue-600 dark:text-blue-400 hover:underline" %>
    </div>
  </div>
</div>