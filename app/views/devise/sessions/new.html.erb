<div class="flex items-center justify-center min-h-screen bg-gray-100">

  <div class="w-full max-w-md bg-white rounded-xl shadow-lg p-6">

    <!-- Heading -->
    <h2 class="text-2xl font-bold text-center text-blue-600 mb-6">
      Login to TurboBlog
    </h2>

    <!-- FORM -->
    <%= form_for(resource, as: resource_name, url: session_path(resource_name), html: { class: "space-y-4" }) do |f| %>

      <!-- Email -->
      <div>
        <%= f.label :email, class: "block mb-1 text-sm font-medium text-gray-700" %>
        <%= f.email_field :email, autofocus: true,
          class: "w-full px-3 py-2 border rounded-lg focus:ring-2 focus:ring-blue-500 outline-none" %>
      </div>

      <!-- Password -->
      <div>
        <%= f.label :password, class: "block mb-1 text-sm font-medium text-gray-700" %>
        <%= f.password_field :password,
          class: "w-full px-3 py-2 border rounded-lg focus:ring-2 focus:ring-blue-500 outline-none" %>
      </div>

      <!-- Remember -->
      <div class="flex items-center">
        <%= f.check_box :remember_me, class: "mr-2" %>
        <%= f.label :remember_me, class: "text-sm text-gray-600" %>
      </div>

      <!-- Submit -->
      <div>
        <%= f.submit "Log in",
          class: "w-full bg-blue-600 hover:bg-blue-700 text-white py-2 rounded-lg font-medium" %>
      </div>

    <% end %>

    <!-- Links -->
    <div class="mt-4 text-center text-sm text-gray-600">
      <%= link_to "Sign up", new_registration_path(resource_name), class: "text-blue-600 hover:underline" %>
      |
      <%= link_to "Forgot password?", new_password_path(resource_name), class: "text-blue-600 hover:underline" %>
    </div>

  </div>

</div>