<div class="flex items-center justify-center min-h-screen bg-gray-100">

  <div class="w-full max-w-md bg-white rounded-xl shadow-lg p-6">

    <h2 class="text-2xl font-bold text-center text-green-600 mb-6">
      Create Account
    </h2>

    <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { class: "space-y-4" }) do |f| %>

      <div>
        <%= f.label :email, class: "block mb-1 text-sm text-gray-700" %>
        <%= f.email_field :email,
          class: "w-full px-3 py-2 border rounded-lg focus:ring-2 focus:ring-green-500" %>
      </div>

      <div>
        <%= f.label :password, class: "block mb-1 text-sm text-gray-700" %>
        <%= f.password_field :password,
          class: "w-full px-3 py-2 border rounded-lg focus:ring-2 focus:ring-green-500" %>
      </div>

      <div>
        <%= f.label :password_confirmation, class: "block mb-1 text-sm text-gray-700" %>
        <%= f.password_field :password_confirmation,
          class: "w-full px-3 py-2 border rounded-lg focus:ring-2 focus:ring-green-500" %>
      </div>

      <%= f.submit "Sign up",
        class: "w-full bg-green-600 hover:bg-green-700 text-white py-2 rounded-lg" %>

    <% end %>

    <div class="mt-4 text-center text-sm">
      Already have an account?
      <%= link_to "Login", new_session_path(resource_name), class: "text-blue-600 hover:underline" %>
    </div>

  </div>

</div>