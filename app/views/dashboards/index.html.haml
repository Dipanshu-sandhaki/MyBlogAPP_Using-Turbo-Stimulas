- period_label = { 'daily' => 'Today', 'weekly' => 'This Week', 'monthly' => 'This Month' }[@period] || 'This Week'
- username = current_user.email.split('@').first.capitalize
- today = Date.today
- today_display = today.strftime("%A, %B %d, %Y")

.dash-root
  %nav.dash-subnav
    .dash-nav-inner
      .dash-nav-left
        .dash-logo
          %svg{width: "18", height: "18", viewBox: "0 0 24 24", fill: "none", stroke: "currentColor", "stroke-width": "2.5"}
            %path{"stroke-linecap": "round", "stroke-linejoin": "round", d: "M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"}
          %span Analytics
        .dash-period-pill= period_label

      .dash-nav-right
        .dash-period-switcher
          = link_to "D", dashboard_path(period: "daily"),   class: "period-btn #{@period == 'daily' ? 'active' : ''}", title: "Daily"
          = link_to "W", dashboard_path(period: "weekly"),  class: "period-btn #{@period.blank? || @period == 'weekly' ? 'active' : ''}", title: "Weekly"
          = link_to "M", dashboard_path(period: "monthly"), class: "period-btn #{@period == 'monthly' ? 'active' : ''}", title: "Monthly"
        .dash-user-chip
          .dash-avatar= username[0].upcase
          %span= username

  .dash-body
    .dash-greeting
      .greeting-left
        %h1.dash-title
          %span.greeting-hi Hey,
          %span.greeting-name= " #{username} 👋"
        %p.dash-subtitle
          Here's how your content performed
          %strong= period_label.downcase
          \.
      .greeting-right
        .live-date-badge
          %svg{width: "13", height: "13", viewBox: "0 0 24 24", fill: "none", stroke: "currentColor", "stroke-width": "2"}
            %path{"stroke-linecap": "round", "stroke-linejoin": "round", d: "M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"}
          %span= today_display

    -# ── KPI ROW ──────────────────────────────────────────────────────────────
    .kpi-grid
      .kpi-card
        .kpi-accent-bar{style: "background:#3b82f6"}
        .kpi-top
          .kpi-label
            .kpi-icon{style: "background:rgba(59,130,246,0.12);color:#3b82f6"}
              %svg{width: "14", height: "14", viewBox: "0 0 24 24", fill: "none", stroke: "currentColor", "stroke-width": "2.5"}
                %path{"stroke-linecap": "round", "stroke-linejoin": "round", d: "M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"}
            %span Posts
          - if @blogs_delta
            %span{class: "kpi-badge #{@blogs_delta >= 0 ? 'up' : 'down'}"}
              = @blogs_delta >= 0 ? "↑ +#{@blogs_delta}%" : "↓ #{@blogs_delta}%"
        .kpi-value= @period_blogs
        .kpi-footer
          .kpi-period-stat
            %span.kpi-period-num= @total_blogs_alltime
            %span.kpi-period-lbl all time
          .kpi-dot
          .kpi-period-stat
            %span.kpi-period-num= @total_drafts
            %span.kpi-period-lbl drafts

      .kpi-card
        .kpi-accent-bar{style: "background:#ef4444"}
        .kpi-top
          .kpi-label
            .kpi-icon{style: "background:rgba(239,68,68,0.12);color:#ef4444"}
              %svg{width: "14", height: "14", viewBox: "0 0 24 24", fill: "currentColor"}
                %path{d: "M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"}
            %span Likes
          - if @likes_delta
            %span{class: "kpi-badge #{@likes_delta >= 0 ? 'up' : 'down'}"}
              = @likes_delta >= 0 ? "↑ +#{@likes_delta}%" : "↓ #{@likes_delta}%"
        .kpi-value= @period_likes
        .kpi-footer
          .kpi-period-stat
            %span.kpi-period-num= @total_likes_alltime
            %span.kpi-period-lbl all time

      .kpi-card
        .kpi-accent-bar{style: "background:#a855f7"}
        .kpi-top
          .kpi-label
            .kpi-icon{style: "background:rgba(168,85,247,0.12);color:#a855f7"}
              %svg{width: "14", height: "14", viewBox: "0 0 24 24", fill: "none", stroke: "currentColor", "stroke-width": "2.5"}
                %path{"stroke-linecap": "round", "stroke-linejoin": "round", d: "M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"}
            %span Comments
          - if @comments_delta
            %span{class: "kpi-badge #{@comments_delta >= 0 ? 'up' : 'down'}"}
              = @comments_delta >= 0 ? "↑ +#{@comments_delta}%" : "↓ #{@comments_delta}%"
        .kpi-value= @period_comments
        .kpi-footer
          .kpi-period-stat
            %span.kpi-period-num= @total_comments_alltime
            %span.kpi-period-lbl all time

      .kpi-card
        .kpi-accent-bar{style: "background:#10b981"}
        .kpi-top
          .kpi-label
            .kpi-icon{style: "background:rgba(16,185,129,0.12);color:#10b981"}
              %svg{width: "14", height: "14", viewBox: "0 0 24 24", fill: "none", stroke: "currentColor", "stroke-width": "2.5"}
                %path{"stroke-linecap": "round", "stroke-linejoin": "round", d: "M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"}
            %span Engagement
          %span.kpi-badge.neutral avg/post
        .kpi-value= @engagement_rate
        .kpi-footer
          .kpi-period-stat
            %span.kpi-period-num= @period_engagement
            %span.kpi-period-lbl interactions #{period_label.downcase}

    -# ── CHART + SIDEBAR ──────────────────────────────────────────────────────
    .section-grid.chart-layout
      .panel.chart-panel
        .panel-header
          %div
            %h2.panel-title Engagement Timeline
            %p.panel-sub
              Likes, comments & posts ·
              %strong= period_label
              · Updated
              %strong= today.strftime("%b %d, %Y")
          .chart-legend
            .legend-item
              %span.legend-dot{style: "background:#3b82f6"}
              Likes
            .legend-item
              %span.legend-dot{style: "background:#a855f7"}
              Comments
            .legend-item
              %span.legend-dot{style: "background:#10b981"}
              Posts

        - if @has_data_in_period
          - cw = 680; ch = 260; pl = 40; pr = 12; pt = 16; pb = 32
          - iw = cw - pl - pr; ih = ch - pt - pb
          - n  = [(@labels.length - 1), 1].max
          - all_vals  = @likes_data + @comments_data + @blogs_data
          - raw_max   = all_vals.max.to_i
          - grid_step = [(raw_max.to_f / 4).ceil, 1].max
          - tick_max  = [grid_step * 4, 1].max
          - series    = [{ data: @likes_data, stroke: '#3b82f6', name: 'Likes' }, { data: @comments_data, stroke: '#a855f7', name: 'Comments' }, { data: @blogs_data, stroke: '#10b981', name: 'Posts' }]
          - label_step = [(@labels.length / 7.0).ceil, 1].max

          .chart-wrapper
            .chart-tooltip#chartTooltip
            %svg.chart-svg{viewBox: "0 0 #{cw} #{ch}", xmlns: "http://www.w3.org/2000/svg", id: "engagementChart", style: "overflow:visible"}
              %defs
                - series.each_with_index do |s, idx|
                  %linearGradient{id: "grad#{idx}", x1: "0", y1: "0", x2: "0", y2: "1"}
                    %stop{offset: "0%", "stop-color": s[:stroke], "stop-opacity": "0.18"}
                    %stop{offset: "100%", "stop-color": s[:stroke], "stop-opacity": "0"}
              - 5.times do |i|
                - tick_val = (grid_step * (4 - i)).round
                - y_pos    = (pt + ih.to_f / 4 * i).round(2)
                %line.chart-grid{x1: pl, y1: y_pos, x2: cw - pr, y2: y_pos}
                %text.chart-tick{x: pl - 6, y: y_pos + 4}= tick_val
              - series.each_with_index do |s, idx|
                - pts = s[:data].each_with_index.map { |v, i| [(pl + (i.to_f / n) * iw).round(2), (pt + ih - ([v, 0].max.to_f / tick_max) * ih).round(2)] }
                - fill_d = "M #{pl},#{pt + ih} " + pts.map { |x, y| "L #{x},#{y}" }.join(" ") + " L #{pl + iw},#{pt + ih} Z"
                %path{d: fill_d, fill: "url(#grad#{idx})", stroke: "none"}
              - series.each_with_index do |s, idx|
                - pts = s[:data].each_with_index.map { |v, i| [(pl + (i.to_f / n) * iw).round(2), (pt + ih - ([v, 0].max.to_f / tick_max) * ih).round(2)] }
                %path{d: "M " + pts.map { |x, y| "#{x},#{y}" }.join(" L "), fill: "none", stroke: s[:stroke], "stroke-width": "2.5", "stroke-linecap": "round", "stroke-linejoin": "round"}
                - pts.each_with_index do |(x, y), i|
                  %circle.chart-dot{cx: x, cy: y, r: "4", fill: "var(--bg-panel)", stroke: s[:stroke], "stroke-width": "2.5",
                    "data-label": (@labels[i] || ''), "data-likes": (@likes_data[i] || 0),
                    "data-comments": (@comments_data[i] || 0), "data-posts": (@blogs_data[i] || 0),
                    style: "cursor:pointer"}
              - @labels.each_with_index do |lbl, i|
                - next unless i % label_step == 0 || i == @labels.length - 1
                %text.chart-label{x: (pl + (i.to_f / n) * iw).round(2), y: ch - 8}= lbl

        - else
          .empty-chart
            %svg{width: "36", height: "36", viewBox: "0 0 24 24", fill: "none", stroke: "currentColor", "stroke-width": "1.5"}
              %path{"stroke-linecap": "round", "stroke-linejoin": "round", d: "M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 013 19.875v-6.75zM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V8.625zM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V4.125z"}
            %p.empty-title No activity #{period_label.downcase}
            %p.empty-sub Publish or promote a blog to see data here

      .sidebar-stack
        - if @best_blog
          .panel.best-post-panel
            .best-post-crown
              %svg{width: "13", height: "13", viewBox: "0 0 24 24", fill: "currentColor"}
                %path{d: "M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z"}
              Best Post
            %p.best-post-title= @best_blog.title
            .best-post-stats
              .bps-item
                %svg{width: "13", height: "13", viewBox: "0 0 24 24", fill: "currentColor"}
                  %path{d: "M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"}
                = @best_blog.likes_count
              .bps-item
                %svg{width: "13", height: "13", viewBox: "0 0 24 24", fill: "none", stroke: "currentColor", "stroke-width": "2.5"}
                  %path{"stroke-linecap": "round", "stroke-linejoin": "round", d: "M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"}
                = @best_blog.comments_count

        .panel.quick-facts
          .qf-row
            .qf-block
              .qf-num= @most_active_day ? @most_active_day.slice(0, 3) : "—"
              .qf-lbl= @most_active_day ? "active day" : "no data yet"
            .qf-divider
            .qf-block
              .qf-num= @total_drafts
              .qf-lbl= @total_drafts == 1 ? "draft" : "drafts"
            .qf-divider
            .qf-block
              .qf-num= @engagement_rate
              .qf-lbl avg / post

        .panel.network-compact
          .panel-header.compact-header
            %h2.panel-title Network
            %p.panel-sub Follow connections
          .network-stats-compact
            .net-stat-compact
              .net-icon-wrap{style: "background:rgba(59,130,246,0.1);color:#3b82f6"}
                %svg{width: "14", height: "14", viewBox: "0 0 24 24", fill: "none", stroke: "currentColor", "stroke-width": "2.5"}
                  %path{"stroke-linecap": "round", "stroke-linejoin": "round", d: "M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"}
              .net-stat-text
                .net-num-compact= @total_followers
                .net-lbl-compact Followers
            .net-stat-compact
              .net-icon-wrap{style: "background:rgba(168,85,247,0.1);color:#a855f7"}
                %svg{width: "14", height: "14", viewBox: "0 0 24 24", fill: "none", stroke: "currentColor", "stroke-width": "2.5"}
                  %path{"stroke-linecap": "round", "stroke-linejoin": "round", d: "M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"}
              .net-stat-text
                .net-num-compact= @total_following
                .net-lbl-compact Following
            - ratio = @total_following > 0 ? (@total_followers.to_f / @total_following).round(2) : @total_followers
            .net-stat-compact
              .net-icon-wrap{style: "background:rgba(16,185,129,0.1);color:#10b981"}
                %svg{width: "14", height: "14", viewBox: "0 0 24 24", fill: "none", stroke: "currentColor", "stroke-width": "2.5"}
                  %path{"stroke-linecap": "round", "stroke-linejoin": "round", d: "M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"}
              .net-stat-text
                .net-num-compact{class: ratio.to_f >= 1 ? 'ratio-good' : 'ratio-low'}= "#{ratio}×"
                .net-lbl-compact Ratio

    -# ── TOP POSTS — FULL WIDTH, MAX 5 ───────────────────────────────────────
    - if @top_blogs.any?
      .panel.top-posts-full
        .panel-header
          %div
            %h2.panel-title Top Posts
            %p.panel-sub By total engagement · all time
          = link_to "View all →", my_blogs_path, class: "panel-link"
        .blog-list
          - rank_colors = %w[#f59e0b #94a3b8 #cd7f32 #64748b #64748b]
          - @top_blogs.each_with_index do |blog, i|
            - eng = blog.likes_count + blog.comments_count
            .blog-row-full
              .blog-rank{style: "color:#{rank_colors[i]}"}= i + 1
              .blog-info
                %p.blog-title= blog.title
                %p.blog-date= blog.created_at.strftime("%b %d, %Y")
              .blog-stats
                .bs-item.likes
                  %svg{width: "12", height: "12", viewBox: "0 0 24 24", fill: "currentColor"}
                    %path{d: "M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"}
                  %span= blog.likes_count
                .bs-item.comments
                  %svg{width: "12", height: "12", viewBox: "0 0 24 24", fill: "none", stroke: "currentColor", "stroke-width": "2.5"}
                    %path{"stroke-linecap": "round", "stroke-linejoin": "round", d: "M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"}
                  %span= blog.comments_count
                %span{class: "eng-badge #{eng > 10 ? 'high' : eng > 3 ? 'mid' : 'low'}"}= eng

    -# ── ACTIVITY: last 24 hours ──────────────────────────────────────────────
    .panel.activity-full-panel
      .panel-header
        %div
          %h2.panel-title Activity
          %p.panel-sub Last 24 hours · all interactions
      - if @recent_activity.any?
        .activity-list
          - @recent_activity.each_with_index do |event, idx|
            - u      = event[:user]
            - init   = u ? u.email[0].upcase : "?"
            - etype  = event[:type]
            - av_cls = case etype
              - when 'like_received'    then 'like-av'
              - when 'comment_received' then 'comment-av'
              - when 'new_follower'     then 'follow-av'
              - when 'i_followed'       then 'ifollowed-av'
              - when 'published'        then 'published-av'
              - when 'i_commented'      then 'icomment-av'
              - else 'comment-av'
            - ic_cls = case etype
              - when 'like_received'    then 'icon-like'
              - when 'comment_received' then 'icon-comment'
              - when 'new_follower'     then 'icon-follow'
              - when 'i_followed'       then 'icon-ifollow'
              - when 'published'        then 'icon-publish'
              - when 'i_commented'      then 'icon-icomment'
              - else 'icon-comment'
            .activity-row{"data-actpage": idx < 6 ? "1" : "2"}
              .activity-avatar{class: av_cls}= init
              .activity-info
                .activity-line
                  %span.activity-who= u ? u.email.split('@').first : "Someone"
                  - case etype
                  - when 'like_received'
                    %span.activity-verb liked your post
                    %span.activity-post= event[:blog]&.title.to_s.truncate(30)
                  - when 'comment_received'
                    %span.activity-verb commented on
                    %span.activity-post= event[:blog]&.title.to_s.truncate(30)
                  - when 'new_follower'
                    %span.activity-verb started following you
                  - when 'i_followed'
                    %span.activity-verb= "you followed"
                    %span.activity-post= u ? u.email.split('@').first : ""
                  - when 'published'
                    %span.activity-verb published
                    %span.activity-post= event[:blog]&.title.to_s.truncate(30)
                  - when 'i_commented'
                    %span.activity-verb you commented on
                    %span.activity-post= event[:blog]&.title.to_s.truncate(30)
                - if ['comment_received', 'i_commented'].include?(etype) && event[:body].present?
                  %p.activity-body= "\"#{event[:body]}\""
                %p.activity-time= time_ago_in_words(event[:at]) + " ago"
              %span.activity-icon{class: ic_cls}
                - case etype
                - when 'like_received'
                  %svg{width: "12", height: "12", viewBox: "0 0 24 24", fill: "currentColor"}
                    %path{d: "M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"}
                - when 'comment_received', 'i_commented'
                  %svg{width: "12", height: "12", viewBox: "0 0 24 24", fill: "none", stroke: "currentColor", "stroke-width": "2.5"}
                    %path{"stroke-linecap": "round", "stroke-linejoin": "round", d: "M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"}
                - when 'new_follower', 'i_followed'
                  %svg{width: "12", height: "12", viewBox: "0 0 24 24", fill: "none", stroke: "currentColor", "stroke-width": "2.5"}
                    %path{"stroke-linecap": "round", "stroke-linejoin": "round", d: "M18 9v3m0 0v3m0-3h3m-3 0h-3m-2-5a4 4 0 11-8 0 4 4 0 018 0zM3 20a6 6 0 0112 0v1H3v-1z"}
                - when 'published'
                  %svg{width: "12", height: "12", viewBox: "0 0 24 24", fill: "none", stroke: "currentColor", "stroke-width": "2.5"}
                    %path{"stroke-linecap": "round", "stroke-linejoin": "round", d: "M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"}
        - if @recent_activity.count > 6
          .panel-footer
            %button.see-more-btn#activityToggle{"data-state": "collapsed", onclick: "toggleActivity()"} See more
      - else
        .empty-state
          %svg{width: "32", height: "32", viewBox: "0 0 24 24", fill: "none", stroke: "currentColor", "stroke-width": "1.5"}
            %path{"stroke-linecap": "round", "stroke-linejoin": "round", d: "M14.857 17.082a23.848 23.848 0 005.454-1.31A8.967 8.967 0 0118 9.75v-.7V9A6 6 0 006 9v.75a8.967 8.967 0 01-2.312 6.022c1.733.64 3.56 1.085 5.455 1.31m5.714 0a24.255 24.255 0 01-5.714 0m5.714 0a3 3 0 11-5.714 0"}
          %p.empty-title No activity in the last 24 hours
          %p.empty-sub Likes, comments, follows & posts will appear here

%script
  :plain
    document.addEventListener('DOMContentLoaded', function () {
      const tooltip = document.getElementById('chartTooltip');
      const svgEl   = document.getElementById('engagementChart');

      if (tooltip && svgEl) {
        document.querySelectorAll('.chart-dot').forEach(function(dot) {
          dot.addEventListener('mouseenter', function () {
            tooltip.innerHTML =
              '<div class="tt-date">' + this.dataset.label + '</div>' +
              '<div class="tt-row"><span class="tt-dot" style="background:#3b82f6"></span><span class="tt-key">Likes</span><span class="tt-val">' + this.dataset.likes + '</span></div>' +
              '<div class="tt-row"><span class="tt-dot" style="background:#a855f7"></span><span class="tt-key">Comments</span><span class="tt-val">' + this.dataset.comments + '</span></div>' +
              '<div class="tt-row"><span class="tt-dot" style="background:#10b981"></span><span class="tt-key">Posts</span><span class="tt-val">' + this.dataset.posts + '</span></div>';
            var svgRect = svgEl.getBoundingClientRect();
            var dotRect = this.getBoundingClientRect();
            tooltip.style.display = 'block';
            tooltip.style.left    = (dotRect.left - svgRect.left + dotRect.width / 2 - 65) + 'px';
            tooltip.style.top     = (dotRect.top  - svgRect.top - 115) + 'px';
          });
          dot.addEventListener('mouseleave', function () { tooltip.style.display = 'none'; });
        });
      }

      window.toggleActivity = function () {
        var btn  = document.getElementById('activityToggle');
        var rows = document.querySelectorAll('.activity-row[data-actpage="2"]');
        if (btn.dataset.state === 'collapsed') {
          rows.forEach(function(r) { r.style.display = 'flex'; });
          btn.textContent = 'See less'; btn.dataset.state = 'expanded';
        } else {
          rows.forEach(function(r) { r.style.display = 'none'; });
          btn.textContent = 'See more'; btn.dataset.state = 'collapsed';
        }
      };

      document.querySelectorAll('.activity-row[data-actpage="2"]').forEach(function(r) { r.style.display = 'none'; });
    });

%style
  :plain
    :root {
      --bg:          #f0f4f8;
      --bg-panel:    #ffffff;
      --bg-hover:    #f8fafc;
      --border:      #e2e8f0;
      --border-soft: #f1f5f9;
      --text-1:      #0d1b2e;
      --text-2:      #334155;
      --text-3:      #64748b;
      --text-4:      #94a3b8;
      --blue:        #3b82f6;
      --purple:      #a855f7;
      --red:         #ef4444;
      --green:       #10b981;
      --amber:       #f59e0b;
      --shadow-sm:   0 1px 4px rgba(0,0,0,.07), 0 1px 2px rgba(0,0,0,.04);
      --shadow-md:   0 4px 16px rgba(0,0,0,.09), 0 1px 4px rgba(0,0,0,.05);
      --radius:      14px;
      --radius-sm:   9px;
      --font:        'DM Sans', -apple-system, BlinkMacSystemFont, sans-serif;
      --font-mono:   'DM Mono', 'Fira Mono', monospace;
    }
    .dark {
      --bg:          #080e1a;
      --bg-panel:    #0f1824;
      --bg-hover:    #162032;
      --border:      #1e2d40;
      --border-soft: #162030;
      --text-1:      #f0f6ff;
      --text-2:      #94afc8;
      --text-3:      #506070;
      --text-4:      #2e404f;
    }
    * { box-sizing: border-box; margin: 0; padding: 0; }

    .dash-root { min-height: 100vh; background: var(--bg); color: var(--text-1); font-family: var(--font); }

    .dash-subnav { background: var(--bg-panel); border-bottom: 1px solid var(--border); }
    .dash-nav-inner { max-width: 1200px; margin: 0 auto; padding: 0 24px; height: 52px; display: flex; align-items: center; justify-content: space-between; }
    .dash-nav-left { display: flex; align-items: center; gap: 10px; }
    .dash-logo { display: flex; align-items: center; gap: 7px; font-size: 14px; font-weight: 900; letter-spacing: -.4px; color: var(--text-1); }
    .dash-logo svg { color: var(--blue); }
    .dash-period-pill { font-size: 11px; font-weight: 700; color: var(--blue); background: rgba(59,130,246,0.10); border: 1px solid rgba(59,130,246,0.20); padding: 3px 10px; border-radius: 20px; }
    .dash-nav-right { display: flex; align-items: center; gap: 10px; }
    .dash-period-switcher { display: flex; gap: 2px; background: var(--bg); border: 1px solid var(--border); border-radius: var(--radius-sm); padding: 3px; }
    .period-btn { padding: 4px 13px; font-size: 12px; font-weight: 800; border-radius: 6px; color: var(--text-3); text-decoration: none; transition: all .15s; }
    .period-btn:hover { color: var(--text-1); background: var(--border); }
    .period-btn.active { background: var(--blue); color: #fff; box-shadow: 0 2px 6px rgba(59,130,246,.35); }
    .dash-user-chip { display: flex; align-items: center; gap: 6px; padding: 4px 10px 4px 4px; border: 1px solid var(--border); border-radius: 20px; font-size: 12px; font-weight: 700; color: var(--text-2); }
    .dash-avatar { width: 26px; height: 26px; border-radius: 50%; background: var(--blue); color: #fff; font-size: 11px; font-weight: 900; display: flex; align-items: center; justify-content: center; }

    .dash-body { max-width: 1200px; margin: 0 auto; padding: 28px 24px 60px; }

    /* ── GREETING — name always high-contrast ── */
    .dash-greeting { margin-bottom: 24px; display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 12px; }
    .dash-title { font-size: 26px; font-weight: 900; letter-spacing: -.6px; line-height: 1.1; }
    .greeting-hi {color: #0d1b2e; }
    html.dark .greeting-hi { color: #ffffff; }
    .greeting-name { color: #0d1b2e; }
    html.dark .greeting-name { color: #ffffff; }
    .dash-subtitle { margin-top: 4px; font-size: 13px; color: var(--text-3); }
    .dash-subtitle strong { color: var(--text-2); }
    .live-date-badge { display: flex; align-items: center; gap: 7px; background: var(--bg-panel); border: 1px solid var(--border); border-radius: 10px; padding: 7px 13px; font-size: 12px; font-weight: 700; color: var(--text-2); box-shadow: var(--shadow-sm); }
    .live-date-badge svg { color: var(--blue); flex-shrink: 0; }

    .panel { background: var(--bg-panel); border: 1px solid var(--border); border-radius: var(--radius); box-shadow: var(--shadow-sm); overflow: hidden; }
    .panel-header { display: flex; align-items: flex-start; justify-content: space-between; padding: 18px 20px 14px; border-bottom: 1px solid var(--border-soft); }
    .compact-header { padding: 13px 16px 9px; }
    .panel-title { font-size: 13px; font-weight: 900; color: var(--text-1); letter-spacing: -.2px; }
    .panel-sub   { font-size: 11px; color: var(--text-3); margin-top: 2px; font-weight: 500; }
    .panel-link  { font-size: 11px; font-weight: 800; color: var(--blue); text-decoration: none; white-space: nowrap; }
    .panel-link:hover { text-decoration: underline; }
    .panel-footer { padding: 11px 20px; border-top: 1px solid var(--border-soft); display: flex; justify-content: center; }
    .see-more-btn { background: none; border: 1.5px solid var(--border); border-radius: 8px; padding: 6px 20px; font-size: 12px; font-weight: 800; color: var(--text-2); cursor: pointer; transition: all .15s; }
    .see-more-btn:hover { border-color: var(--blue); color: var(--blue); background: rgba(59,130,246,0.05); }

    .kpi-grid { display: grid; grid-template-columns: repeat(4,1fr); gap: 14px; margin-bottom: 20px; }
    @media(max-width:900px){.kpi-grid{grid-template-columns:repeat(2,1fr);}}
    @media(max-width:480px){.kpi-grid{grid-template-columns:1fr;}}
    .kpi-card { background: var(--bg-panel); border: 1px solid var(--border); border-radius: var(--radius); padding: 18px 20px 16px; box-shadow: var(--shadow-sm); position: relative; overflow: hidden; }
    .kpi-accent-bar { position: absolute; top: 0; left: 0; right: 0; height: 3px; }
    .kpi-top { display: flex; align-items: center; justify-content: space-between; margin-bottom: 14px; }
    .kpi-label { display: flex; align-items: center; gap: 7px; font-size: 11px; font-weight: 800; color: var(--text-2); text-transform: uppercase; letter-spacing: .07em; }
    .kpi-icon { width: 28px; height: 28px; border-radius: 8px; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
    .kpi-badge { font-size: 11px; font-weight: 900; padding: 3px 8px; border-radius: 20px; }
    .kpi-badge.up      { background: #dcfce7; color: #15803d; }
    .kpi-badge.down    { background: #fee2e2; color: #dc2626; }
    .kpi-badge.neutral { background: var(--bg); color: var(--text-2); border: 1px solid var(--border); font-size: 10px; }
    .dark .kpi-badge.up   { background: rgba(16,185,129,.18); color: #4ade80; }
    .dark .kpi-badge.down { background: rgba(239,68,68,.18);  color: #f87171; }
    .kpi-value { font-size: 38px; font-weight: 900; letter-spacing: -2px; line-height: 1; color: var(--text-1); margin-bottom: 10px; font-variant-numeric: tabular-nums; }
    .kpi-footer { display: flex; align-items: center; gap: 8px; }
    .kpi-period-stat { display: flex; align-items: baseline; gap: 3px; }
    .kpi-period-num  { font-weight: 800; color: var(--text-2); font-size: 12px; }
    .kpi-period-lbl  { font-weight: 500; color: var(--text-4); font-size: 11px; }
    .kpi-dot { width: 3px; height: 3px; border-radius: 50%; background: var(--border); flex-shrink: 0; }

    .section-grid { display: grid; gap: 16px; margin-bottom: 18px; }
    .chart-layout { grid-template-columns: 1fr 288px; }
    @media(max-width:960px){ .chart-layout { grid-template-columns: 1fr; } }

    .chart-wrapper { position: relative; padding: 8px 14px 4px; }
    .chart-svg  { width: 100%; display: block; overflow: visible; }
    .chart-grid { stroke: var(--border); stroke-width: 1; }
    .chart-tick  { fill: var(--text-3); font-size: 10px; font-weight: 700; text-anchor: end; font-family: var(--font-mono); }
    .chart-label { fill: var(--text-3); font-size: 10px; font-weight: 700; text-anchor: middle; }
    .chart-dot { cursor: pointer; }
    .chart-dot:hover { r: 6; }
    .chart-legend { display: flex; align-items: center; gap: 14px; flex-wrap: wrap; }
    .legend-item { display: flex; align-items: center; gap: 5px; font-size: 11px; color: var(--text-2); font-weight: 700; }
    .legend-dot { width: 8px; height: 8px; border-radius: 50%; flex-shrink: 0; }

    .chart-tooltip { display: none; position: absolute; pointer-events: none; z-index: 20; background: var(--bg-panel); border: 1.5px solid var(--border); border-radius: 10px; padding: 10px 13px; box-shadow: var(--shadow-md); min-width: 130px; }
    .tt-date { font-size: 11px; font-weight: 900; color: var(--text-1); margin-bottom: 7px; text-transform: uppercase; letter-spacing:.05em; }
    .tt-row  { display: flex; align-items: center; gap: 7px; margin-bottom: 4px; font-size: 12px; }
    .tt-row:last-child { margin-bottom: 0; }
    .tt-dot  { width: 7px; height: 7px; border-radius: 50%; flex-shrink: 0; }
    .tt-key  { flex: 1; color: var(--text-3); font-weight: 600; }
    .tt-val  { font-weight: 900; color: var(--text-1); }

    .empty-chart { height: 240px; display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 10px; margin: 12px 14px; border-radius: 10px; border: 2px dashed var(--border); }
    .empty-chart svg { color: var(--text-4); }

    .sidebar-stack { display: flex; flex-direction: column; gap: 12px; }
    .best-post-panel { padding: 16px 18px; }
    .best-post-crown { display: flex; align-items: center; gap: 6px; font-size: 10px; font-weight: 900; text-transform: uppercase; letter-spacing: .08em; color: var(--amber); margin-bottom: 10px; }
    .best-post-title { font-size: 13px; font-weight: 800; color: var(--text-1); line-height: 1.4; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; margin-bottom: 12px; }
    .best-post-stats { display: flex; gap: 16px; }
    .bps-item { display: flex; align-items: center; gap: 5px; font-size: 13px; font-weight: 900; color: var(--text-1); }
    .bps-item:first-child svg { color: var(--red); }
    .bps-item:last-child  svg { color: var(--purple); }

    .quick-facts { padding: 16px 18px; }
    .qf-row { display: flex; align-items: center; justify-content: space-between; }
    .qf-block { flex: 1; text-align: center; }
    .qf-num { font-size: 20px; font-weight: 900; letter-spacing: -.5px; color: var(--text-1); font-variant-numeric: tabular-nums; }
    .qf-lbl { font-size: 10px; font-weight: 700; color: var(--text-3); margin-top: 3px; text-transform: uppercase; letter-spacing: .05em; }
    .qf-divider { width: 1px; height: 36px; background: var(--border); flex-shrink: 0; }

    .network-compact {}
    .network-stats-compact { display: flex; flex-direction: column; padding: 6px 0 8px; }
    .net-stat-compact { display: flex; align-items: center; gap: 12px; padding: 10px 16px; border-bottom: 1px solid var(--border-soft); }
    .net-stat-compact:last-child { border-bottom: none; }
    .net-icon-wrap { width: 32px; height: 32px; border-radius: 9px; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
    .net-stat-text { flex: 1; }
    .net-num-compact { font-size: 18px; font-weight: 900; color: var(--text-1); font-variant-numeric: tabular-nums; letter-spacing: -.5px; }
    .net-num-compact.ratio-good { color: var(--green); }
    .net-num-compact.ratio-low  { color: var(--amber); }
    .net-lbl-compact { font-size: 11px; font-weight: 700; color: var(--text-3); margin-top: 1px; }

    .top-posts-full { margin-bottom: 18px; }
    .blog-row-full { display: flex; align-items: center; gap: 16px; padding: 14px 24px; border-bottom: 1px solid var(--border-soft); transition: background .12s; }
    .blog-row-full:last-child { border-bottom: none; }
    .blog-row-full:hover { background: var(--bg-hover); }
    .blog-rank  { font-size: 13px; font-weight: 900; width: 22px; text-align: center; flex-shrink: 0; }
    .blog-info  { flex: 1; min-width: 0; }
    .blog-title { font-size: 14px; font-weight: 800; color: var(--text-1); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .blog-date  { font-size: 11px; color: var(--text-3); margin-top: 3px; }
    .blog-stats { display: flex; align-items: center; gap: 10px; flex-shrink: 0; }
    .bs-item    { display: flex; align-items: center; gap: 4px; font-size: 13px; font-weight: 800; color: var(--text-2); }
    .bs-item.likes    svg { color: var(--red); }
    .bs-item.comments svg { color: var(--purple); }
    .eng-badge { font-size: 10px; font-weight: 900; padding: 2px 8px; border-radius: 20px; }
    .eng-badge.high { background: #dcfce7; color: #15803d; }
    .eng-badge.mid  { background: #dbeafe; color: #1e40af; }
    .eng-badge.low  { background: var(--bg); color: var(--text-3); border: 1px solid var(--border); }
    .dark .eng-badge.high { background: rgba(16,185,129,.18); color: #4ade80; }
    .dark .eng-badge.mid  { background: rgba(59,130,246,.18); color: #60a5fa; }

    .activity-full-panel { margin-bottom: 18px; }
    .activity-row { display: flex; align-items: flex-start; gap: 11px; padding: 12px 20px; border-bottom: 1px solid var(--border-soft); transition: background .12s; }
    .activity-row:last-child { border-bottom: none; }
    .activity-row:hover { background: var(--bg-hover); }
    .activity-avatar { width: 32px; height: 32px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 12px; font-weight: 900; flex-shrink: 0; }
    .like-av       { background: rgba(239,68,68,.12);  color: var(--red); }
    .comment-av    { background: rgba(168,85,247,.12); color: var(--purple); }
    .follow-av     { background: rgba(59,130,246,.12); color: var(--blue); }
    .ifollowed-av  { background: rgba(6,182,212,.12);  color: #06b6d4; }
    .published-av  { background: rgba(16,185,129,.12); color: var(--green); }
    .icomment-av   { background: rgba(245,158,11,.12); color: var(--amber); }
    .activity-info { flex: 1; min-width: 0; }
    .activity-line { display: flex; flex-wrap: wrap; align-items: baseline; gap: 4px; }
    .activity-who  { font-size: 12px; font-weight: 900; color: var(--text-1); }
    .activity-verb { font-size: 12px; color: var(--text-3); font-weight: 500; }
    .activity-post { font-size: 12px; font-weight: 800; color: var(--blue); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; max-width: 220px; }
    .activity-body { font-size: 11px; color: var(--text-3); margin-top: 3px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; font-style: italic; }
    .activity-time { font-size: 11px; color: var(--text-4); margin-top: 3px; font-weight: 600; }
    .activity-icon { width: 24px; height: 24px; border-radius: 50%; display: flex; align-items: center; justify-content: center; flex-shrink: 0; margin-top: 2px; }
    .icon-like     { background: rgba(239,68,68,.12);  color: var(--red); }
    .icon-comment  { background: rgba(168,85,247,.12); color: var(--purple); }
    .icon-follow   { background: rgba(59,130,246,.12); color: var(--blue); }
    .icon-ifollow  { background: rgba(6,182,212,.12);  color: #06b6d4; }
    .icon-publish  { background: rgba(16,185,129,.12); color: var(--green); }
    .icon-icomment { background: rgba(245,158,11,.12); color: var(--amber); }

    .empty-state { display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 48px 24px; gap: 10px; }
    .empty-state svg { color: var(--text-4); }
    .empty-title { font-size: 13px; font-weight: 800; color: var(--text-3); }
    .empty-sub   { font-size: 12px; color: var(--text-4); }