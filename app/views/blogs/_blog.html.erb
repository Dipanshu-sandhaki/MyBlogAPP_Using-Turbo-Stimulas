<div id="<%= dom_id(blog) %>"
     class="bg-white p-5 rounded-2xl border border-gray-200
       shadow-sm hover:shadow-lg hover:-translate-y-0.5
       transition-all duration-200
       flex justify-between gap-4
       w-full">

  <!-- LEFT CONTENT -->
  <div class="flex items-start gap-3 flex-1 min-w-0">

    <!-- CHECKBOX -->
    <input type="checkbox"
       value="<%= blog.id %>"
       data-bulk-select-target="checkbox"
       data-action="change->bulk-select#updateSelection"
       class="mt-1 w-4 h-4 flex-shrink-0 opacity-0 pointer-events-none transition">

    <div class="flex-1">

      <h3 class="text-lg font-semibold text-gray-900 truncate">
        <%= blog.title.presence || "Untitled Blog" %>
      </h3>

      <div class="h-[2px] bg-blue-500/60 my-2 w-10 rounded-full"></div>

      <p class="text-gray-800 text-sm leading-relaxed line-clamp-2">
        <%= blog.body.present? ? blog.body : "No content available..." %>
      </p>

      <div class="mt-3 flex items-center gap-2">
        <span class="text-xs text-gray-600">
          <%= time_ago_in_words(blog.created_at) %> ago
        </span>
      </div>

    </div>
  </div>

  <!-- RIGHT ACTIONS -->
  <div data-bulk-select-target="actions"
       class="flex items-center gap-2 shrink-0">

    <!-- VIEW -->
    <%= link_to blog_path(blog),
        data: { turbo_frame: "modal" },
        class: "p-2 rounded-lg bg-blue-50 hover:bg-blue-100 hover:scale-105 transition-all duration-150" do %>
      <svg xmlns="http://www.w3.org/2000/svg" fill="none"
           viewBox="0 0 24 24" stroke-width="1.5"
           stroke="currentColor"
           class="w-5 h-5 text-blue-600">
        <path stroke-linecap="round" stroke-linejoin="round"
          d="M2.25 12s3.75-7.5 9.75-7.5S21.75 12 21.75 12s-3.75 7.5-9.75 7.5S2.25 12 2.25 12z" />
        <path stroke-linecap="round" stroke-linejoin="round"
          d="M12 15.75A3.75 3.75 0 1 0 12 8.25a3.75 3.75 0 0 0 0 7.5z" />
      </svg>
    <% end %>

    <!-- EDIT -->
    <%= link_to edit_blog_path(blog),
        data: { turbo_frame: "modal" },
        class: "p-2 rounded-lg bg-yellow-50 hover:bg-yellow-100 hover:scale-105 transition-all duration-150" do %>
      <svg xmlns="http://www.w3.org/2000/svg" fill="none"
           viewBox="0 0 24 24" stroke-width="1.5"
           stroke="currentColor"
           class="w-5 h-5 text-yellow-600">
        <path stroke-linecap="round" stroke-linejoin="round"
          d="M16.862 3.487a2.1 2.1 0 113 2.97L7.5 18.82l-4.5 1.5 1.5-4.5 12.362-12.333z" />
      </svg>
    <% end %>

    <!-- DELETE -->
   <button
  type="button"
  data-action="click->modal#openDelete"
  data-url="<%= blog_path(blog) %>"
  class="p-2 rounded-lg bg-red-50 hover:bg-red-100">

  <svg xmlns="http://www.w3.org/2000/svg"
       class="w-5 h-5 text-red-600"
       fill="none"
       viewBox="0 0 24 24"
       stroke="currentColor">
    <path stroke-linecap="round" stroke-linejoin="round"
      d="M6 7h12M9 7V4h6v3m-7 4v6m4-6v6m5-10l-1 12H6L5 7h14z"/>
  </svg>
</button>
  </div>
</div>