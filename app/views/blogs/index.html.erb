<div class="min-h-screen bg-gray-100 py-10" data-controller="bulk-select">

  <!-- MAIN CENTER WRAPPER -->
  <div class="max-w-2xl mx-auto px-6">

    <!-- HEADING -->
    <h1 class="text-4xl font-bold text-gray-800 text-center mb-8">
      My Blogs
    </h1>

    <!-- ACTION BAR -->
    <div class="flex items-center justify-between mb-6">

      <!-- LEFT : SELECT -->
      <label class="flex items-center gap-2 text-sm cursor-pointer">
        <input type="checkbox"
               data-action="bulk-select#toggleAll"
               class="w-4 h-4">
        Select All
      </label>

      <!-- RIGHT : BUTTONS -->
      <div class="flex items-center gap-3">

        <!-- DELETE SELECTED -->
        <button
          data-bulk-select-target="deleteBtn"
          data-action="bulk-select#deleteSelected"
          class="hidden bg-red-600 text-white px-3 py-1 rounded-md shadow hover:bg-red-700 transition whitespace-nowrap">
          Delete Selected
        </button>

        <!-- CREATE BLOG -->
        <%= link_to new_blog_path,
            data: { turbo_frame: "modal" },
            class: "flex items-center gap-2 bg-blue-600 text-sm text-white px-3 py-1 rounded-md shadow hover:bg-blue-700 transition whitespace-nowrap" do %>
          <span class="text-sm">+</span>
          <span>Create Blog</span>
        <% end %>

        <!-- BULK UPLOAD -->
        <%= link_to bulk_upload_blogs_path,
            data: { turbo_frame: "modal" },
            class: "flex items-center gap-2 bg-gray-800 text-sm text-white px-3 py-1.5 rounded-md shadow hover:bg-gray-900 transition whitespace-nowrap" do %>
          <span>📂</span>
          <span>Bulk Upload</span>
        <% end %>

      </div>
    </div>

    <!-- BLOG LIST -->
    <div id="blogs" class="space-y-4">
      <%= render @blogs %>
    </div>

  </div>

</div>