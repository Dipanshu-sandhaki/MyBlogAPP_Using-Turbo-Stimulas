<div class="min-h-screen bg-gray-950 py-10 px-4" data-controller="blog-editor">
  <div class="max-w-3xl mx-auto">

    <div class="mb-8">
      <%= link_to my_blogs_path,
          class: "inline-flex items-center gap-1.5 text-sm text-gray-400 hover:text-white transition mb-5" do %>
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/>
        </svg>
        Back to My Blogs
      <% end %>
      <div class="flex items-center gap-3 mt-2">
        <div class="w-9 h-9 rounded-lg bg-indigo-600 flex items-center justify-center shrink-0">
          <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
              d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
          </svg>
        </div>
        <div>
          <h1 class="text-2xl font-bold text-white tracking-tight">
            <%= blog.persisted? ? "Edit Blog" : "New Blog" %>
          </h1>
          <p class="text-sm text-gray-500 mt-0.5">
            <%= blog.persisted? ? "Update your post" : "Write something worth reading" %>
          </p>
        </div>
      </div>
    </div>

    <%= form_with(model: blog, local: true, html: { enctype: "multipart/form-data" }) do |f| %>

      <% if blog.errors.any? %>
        <div class="mb-5 bg-red-950 border border-red-800 rounded-xl p-4">
          <p class="text-red-400 text-sm font-medium mb-1">Please fix the following:</p>
          <% blog.errors.full_messages.each do |msg| %>
            <p class="text-red-300 text-sm mt-1">• <%= msg %></p>
          <% end %>
        </div>
      <% end %>

      <div class="space-y-5">

        <div class="form-field">
          <label class="be-label">Title <span class="text-indigo-400">*</span></label>
          <%= f.text_field :title, placeholder: "Your blog title...", class: "be-input text-xl font-semibold" %>
        </div>

        <div class="form-field be-card">
          <label class="be-label">Cover Image <span class="be-optional">(optional)</span></label>
          <% if blog.persisted? && blog.cover_image.attached? %>
            <%= image_tag blog.cover_image, class: "w-full max-h-48 object-cover rounded-lg mb-3 border border-gray-700" %>
          <% end %>
          <label class="cursor-pointer flex items-center gap-3 group">
            <div class="be-file-btn group-hover:bg-indigo-600 group-hover:border-indigo-500 group-hover:text-white">
              Choose file
            </div>
            <span class="text-sm text-gray-500" id="file-label">No file chosen</span>
            <%= f.file_field :cover_image, accept: "image/*", class: "hidden", id: "cover_image_input", onchange: "previewCover(this)" %>
          </label>
          <img id="cover-preview" class="cover-preview" alt="Cover preview" />
        </div>

        <div class="form-field">
          <label class="be-label">Content <span class="text-indigo-400">*</span></label>

          <trix-toolbar id="blog-toolbar">
            <div class="be-toolbar">

              <div class="be-group">
                <button type="button" class="be-btn" data-trix-action="undo" title="Undo">
                  <svg viewBox="0 0 24 24"><path d="M3 7v6h6"/><path d="M3 13a9 9 0 1 0 2.34-6"/></svg>
                </button>
                <button type="button" class="be-btn" data-trix-action="redo" title="Redo">
                  <svg viewBox="0 0 24 24"><path d="M21 7v6h-6"/><path d="M21 13a9 9 0 1 1-2.34-6"/></svg>
                </button>
              </div>

              <div class="be-group">
                <button type="button" class="be-btn be-btn--text" data-trix-attribute="bold" title="Bold" style="font-weight:900">B</button>
                <button type="button" class="be-btn be-btn--text" data-trix-attribute="italic" title="Italic" style="font-style:italic">I</button>
                <button type="button" class="be-btn be-btn--text" data-trix-attribute="strike" title="Strikethrough" style="text-decoration:line-through">S</button>
              </div>

              <div class="be-group">
                <button type="button" class="be-btn" title="Larger text" data-action="click->blog-editor#increaseFontSize">
                  <svg viewBox="0 0 24 24"><text x="2" y="17" font-size="14" font-weight="700" fill="currentColor">A</text><text x="13" y="13" font-size="9" fill="currentColor">+</text></svg>
                </button>
                <button type="button" class="be-btn" title="Smaller text" data-action="click->blog-editor#decreaseFontSize">
                  <svg viewBox="0 0 24 24"><text x="2" y="17" font-size="14" font-weight="700" fill="currentColor">A</text><text x="13" y="16" font-size="11" fill="currentColor">-</text></svg>
                </button>
              </div>

              <div class="be-group">
                <button type="button" class="be-btn be-btn--color" title="Text color" data-action="click->blog-editor#openColorPicker">
                  <svg viewBox="0 0 24 24">
                    <text x="4" y="16" font-size="13" font-weight="700" fill="currentColor">A</text>
                    <rect x="4" y="18" width="16" height="3" rx="1" id="color-indicator" fill="#6366f1"/>
                  </svg>
                  <input type="color" id="text-color-picker" class="be-color-input"
                         data-action="input->blog-editor#applyColor" value="#6366f1">
                </button>
              </div>

              <div class="be-group">
                <button type="button" class="be-btn be-btn--text" title="Toggle case" data-action="click->blog-editor#toggleCase">Aa</button>
              </div>

              <div class="be-group">
                <button type="button" class="be-btn be-btn--text" data-trix-attribute="heading1" title="Heading 1">H₁</button>
                <button type="button" class="be-btn" data-trix-attribute="quote" title="Blockquote">
                  <svg viewBox="0 0 24 24"><path d="M3 21c3 0 7-1 7-8V5c0-1.25-.756-2.017-2-2H4c-1.25 0-2 .75-2 1.972V11c0 1.25.75 2 2 2 1 0 1 0 1 1v1c0 1-1 2-2 2s-1 .008-1 1.031V20c0 1 0 1 1 1z"/><path d="M15 21c3 0 7-1 7-8V5c0-1.25-.757-2.017-2-2h-4c-1.25 0-2 .75-2 1.972V11c0 1.25.75 2 2 2h.75c0 2.25.25 4-2.75 4v3c0 1 0 1 1 1z"/></svg>
                </button>
                <button type="button" class="be-btn be-btn--text" data-trix-attribute="code" title="Code">&lt;/&gt;</button>
              </div>

              <div class="be-group">
                <button type="button" class="be-btn" data-trix-attribute="bullet" title="Bullet list">
                  <svg viewBox="0 0 24 24"><line x1="9" y1="6" x2="20" y2="6"/><line x1="9" y1="12" x2="20" y2="12"/><line x1="9" y1="18" x2="20" y2="18"/><circle cx="4" cy="6" r="1.5" fill="currentColor"/><circle cx="4" cy="12" r="1.5" fill="currentColor"/><circle cx="4" cy="18" r="1.5" fill="currentColor"/></svg>
                </button>
                <button type="button" class="be-btn" data-trix-attribute="number" title="Numbered list">
                  <svg viewBox="0 0 24 24"><line x1="10" y1="6" x2="21" y2="6"/><line x1="10" y1="12" x2="21" y2="12"/><line x1="10" y1="18" x2="21" y2="18"/><path d="M4 6h1v4"/><path d="M4 10h2"/><path d="M6 18H4c0-1 2-2 2-3s-1-1.5-2-1"/></svg>
                </button>
              </div>

              <div class="be-group">
                <button type="button" class="be-btn" title="Link" data-action="click->blog-editor#toggleLinkDialog">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/>
                    <path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/>
                  </svg>
                </button>
              </div>

            </div>

            <div class="be-link-dialog" id="be-link-dialog" style="display:none;">
              <div class="be-link-row">
                <svg class="be-link-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/>
                  <path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/>
                </svg>
                <input class="be-link-input" type="url" id="be-link-url-input" placeholder="Paste or type URL…">
                <button type="button" class="be-link-btn be-link-btn--apply" data-action="click->blog-editor#applyLink">Apply</button>
                <button type="button" class="be-link-btn be-link-btn--remove" data-action="click->blog-editor#removeLink">Remove</button>
              </div>
            </div>

          </trix-toolbar>

          <%= f.rich_text_area :content, toolbar: "blog-toolbar", class: "trix-content" %>
        </div>

        <div class="form-field pt-2 flex items-center gap-3">
          <%= f.submit blog.persisted? ? "Update Blog" : "Publish Blog",
              class: "flex-1 bg-indigo-600 hover:bg-indigo-500 active:scale-[0.99] text-white py-3 rounded-xl font-semibold transition cursor-pointer text-base" %>
          <%= link_to "Discard", my_blogs_path,
              class: "px-6 py-3 rounded-xl border border-gray-700 text-gray-400 hover:border-gray-500 hover:text-white transition text-sm" %>
        </div>

      </div>
    <% end %>
  </div>
</div>

<script>
  function previewCover(input) {
    const label   = document.getElementById('file-label')
    const preview = document.getElementById('cover-preview')
    if (input.files?.[0]) {
      label.textContent = input.files[0].name
      const r = new FileReader()
      r.onload = e => { preview.src = e.target.result; preview.style.display = 'block' }
      r.readAsDataURL(input.files[0])
    }
  }
</script>