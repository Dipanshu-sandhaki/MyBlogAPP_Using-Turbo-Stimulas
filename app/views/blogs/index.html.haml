.page-wrapper.min-h-screen.bg-gray-50.dark:bg-gray-900.pt-8.pb-16.transition-colors.duration-300{"data-bulk-select-all-ids-value" => "#{@all_blog_ids.to_json}", "data-controller" => "bulk-select modal"}
  .max-w-4xl.mx-auto.px-6.mb-8
    = link_to root_path, class: "inline-flex items-center gap-1.5 text-sm font-bold tracking-wide text-gray-900 dark:text-white hover:text-blue-600 dark:hover:text-blue-400 transition-colors duration-150" do
      %svg.w-4.h-4.stroke-current{fill: "none", stroke: "currentColor", "stroke-width" => "2.5", viewbox: "0 0 24 24", xmlns: "http://www.w3.org/2000/svg"}
        %path{d: "M15 19l-7-7 7-7", "stroke-linecap" => "round", "stroke-linejoin" => "round"}
      Back to Feed
  .max-w-4xl.mx-auto.px-6
    .mb-8
      %h1.text-4xl.sm:text-5xl.font-extrabold.text-gray-900.dark:text-white.tracking-tight
        My Blogs
      %p.mt-2.text-base.text-gray-500.dark:text-gray-400.font-medium
        Manage and organize your published content and drafts.
    #action_bar.mb-6
      = render "blogs/action_bar", blogs: @blogs

    #blogs_list_container
      - if @blogs.empty? && @page == 1
        #blogs_list_target
          .mt-12.flex.flex-col.items-center.justify-center.py-20.text-center.bg-white.dark:bg-gray-800.rounded-3xl.border.border-gray-200.dark:border-gray-700.shadow-sm.border-dashed.transition-colors
            .w-20.h-20.rounded-2xl.bg-blue-50.dark:bg-gray-700.text-blue-600.dark:text-blue-400.flex.items-center.justify-center.mb-6
              %svg.w-10.h-10.stroke-current{fill: "none", "stroke-width" => "1.5", viewbox: "0 0 24 24"}
                %path{d: "M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m5.231 13.481L15 17.25m-4.5-15H5.625c-.621 0-1.125.504-1.125 1.125v16.5c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9zm3.75 11.625a2.625 2.625 0 11-5.25 0 2.625 2.625 0 015.25 0z", "stroke-linecap" => "round", "stroke-linejoin" => "round"}
            %h3.text-xl.font-bold.text-gray-900.dark:text-white.mb-2 No blogs found
            %p.text-gray-500.dark:text-gray-400.max-w-sm
              Your workspace is empty. Create a new blog or upload via CSV to get started.
      - else
        #blogs_list_target.space-y-4
          = render @blogs

        %turbo-frame{id: "load_more_button"}
          - if @has_more
            .mt-8.flex.justify-center.pb-4
              = link_to my_blogs_path(page: @page + 1), data: { turbo_stream: true }, class: "inline-flex items-center gap-2 px-8 py-3 rounded-full text-sm font-bold tracking-wide bg-white dark:bg-gray-800 text-gray-900 dark:text-white border-2 border-gray-200 dark:border-gray-700 hover:border-blue-500 hover:text-blue-600 dark:hover:border-blue-400 dark:hover:text-blue-400 shadow-sm hover:shadow-md transition-all duration-200 group" do
                %svg.w-4.h-4.stroke-current.group-hover:animate-bounce{fill: "none", "stroke-width" => "2.5", viewbox: "0 0 24 24", xmlns: "http://www.w3.org/2000/svg"}
                  %path{d: "M19 9l-7 7-7-7", "stroke-linecap" => "round", "stroke-linejoin" => "round"}
                Load More

  / Modals
  %div{class: "fixed inset-0 z-[9999] flex items-center justify-center pointer-events-none p-4 sm:p-6 hidden", "data-modal-target" => "modal"}
    %div{class: "absolute inset-0 bg-black/50 backdrop-blur-sm pointer-events-auto", "data-action" => "click->modal#close"}
    %div{class: "relative w-full max-w-4xl pointer-events-auto rounded-3xl shadow-2xl overflow-hidden bg-white dark:bg-gray-900"}
      %div{class: "max-h-[85vh] overflow-y-auto custom-scrollbar", id: "global-modal-scroll"}
        = turbo_frame_tag "modal", target: "_top"

  %div{id: "deleteModal", class: "hidden fixed inset-0 z-[9999] flex items-center justify-center", "data-modal-target" => "deleteModal"}
    %div{class: "absolute inset-0 bg-black/50 backdrop-blur-sm", "data-action" => "click->modal#closeDelete"}
    .relative.bg-white.dark:bg-gray-800.p-6.rounded-2xl.shadow-xl.max-w-md.w-full.mx-4.transform.transition-all
      %h3.text-xl.font-extrabold.text-gray-900.dark:text-white.mb-2
        Delete Blog?
      %p.text-sm.text-gray-600.dark:text-gray-400.mb-6
        Are you sure you want to delete this blog? This action cannot be undone.
      .flex.justify-end.gap-3
        %button.px-4.py-2.rounded-xl.bg-gray-100.dark:bg-gray-700.text-gray-700.dark:text-gray-300.hover:bg-gray-200.dark:hover:bg-gray-600.transition-colors.font-semibold{"data-action" => "click->modal#closeDelete", type: "button"}
          Cancel
        %button.px-4.py-2.rounded-xl.bg-red-600.hover:bg-red-700.text-white.transition-colors.font-semibold{"data-action" => "click->modal#confirmDelete", type: "button"}
          Delete

  %div{id: "bulk-delete-modal", class: "hidden fixed inset-0 z-[9999] flex items-center justify-center", "data-bulk-select-target" => "bulkDeleteModal"}
    %div{class: "absolute inset-0 bg-black/50 backdrop-blur-sm", "data-action" => "click->bulk-select#closeBulkDeleteModal"}
    .relative.bg-white.dark:bg-gray-800.p-6.rounded-2xl.shadow-xl.max-w-md.w-full.mx-4.transform.transition-all
      %h3.text-xl.font-extrabold.text-gray-900.dark:text-white.mb-2
        Delete Selected Blogs?
      %p.text-sm.text-gray-600.dark:text-gray-400.mb-6
        Are you sure you want to delete
        %span.font-bold.text-red-500{"data-bulk-select-target" => "bulkDeleteCount"} 0
        selected blogs? This action cannot be undone.
      .flex.justify-end.gap-3
        %button.px-4.py-2.rounded-xl.bg-gray-100.dark:bg-gray-700.text-gray-700.dark:text-gray-300.hover:bg-gray-200.dark:hover:bg-gray-600.transition-colors.font-semibold{"data-action" => "click->bulk-select#closeBulkDeleteModal", type: "button"}
          Cancel
        %button.px-4.py-2.rounded-xl.bg-red-600.hover:bg-red-700.text-white.transition-colors.font-semibold{"data-action" => "click->bulk-select#confirmBulkDelete", type: "button"}
          Delete

:css
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(20px); }
    to   { opacity: 1; transform: translateY(0); }
  }