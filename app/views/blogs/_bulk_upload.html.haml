%turbo-frame#modal
  %div{"data-controller" => "bulk-upload"}

    / Header
    .px-6.py-4.flex.justify-between.items-center.border-b.bg-white.dark:bg-gray-800.border-gray-200.dark:border-gray-700
      .flex.items-center.gap-3
        .w-8.h-8.rounded-lg.bg-blue-600.flex.items-center.justify-center.shrink-0
          %svg.w-4.h-4.text-white{fill: "none", stroke: "currentColor", "stroke-width" => "2", viewbox: "0 0 24 24"}
            %path{d: "M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5m-13.5-9L12 3m0 0l4.5 4.5M12 3v13.5", "stroke-linecap" => "round", "stroke-linejoin" => "round"}
        %div
          %h2.text-base.font-bold.text-gray-900.dark:text-white Bulk Upload Blogs
          %p.text-xs.text-gray-500.dark:text-gray-400 Upload multiple blogs via CSV file
      %button.group.w-8.h-8.rounded-lg.flex.items-center.justify-center.transition-all.duration-200.bg-gray-100.dark:bg-gray-700.hover:bg-red-500{"data-action" => "click->modal#close", type: "button"}
        %svg.w-4.h-4.text-gray-500.dark:text-gray-400.group-hover:text-white.transition-colors.duration-200{fill: "none", stroke: "currentColor", "stroke-width" => "2.5", viewbox: "0 0 24 24"}
          %path{d: "M6 18L18 6M6 6l12 12", "stroke-linecap" => "round", "stroke-linejoin" => "round"}

    / Body
    .bg-gray-50.dark:bg-gray-900.px-6.py-6.space-y-4
      = form_with url: bulk_create_blogs_path, method: :post, html: { multipart: true, target: "_top" }, data: { turbo: false } do |f|

        / CSV Format Info
        .rounded-xl.border.p-4.bg-blue-50.border-blue-200.dark:bg-gray-800.dark:border-blue-700
          .flex.items-start.gap-3
            %svg.w-5.h-5.text-blue-500.dark:text-blue-400.shrink-0{class: "mt-0.5", fill: "none", stroke: "currentColor", "stroke-width" => "2", viewbox: "0 0 24 24"}
              %path{d: "M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z", "stroke-linecap" => "round", "stroke-linejoin" => "round"}
            %div
              %p.text-sm.font-semibold.text-blue-700.dark:text-blue-300.mb-1 CSV Format Required
              %p.text-xs.text-blue-600.dark:text-blue-400.mb-2 Your CSV must have these columns:
              .flex.gap-2
                %span.inline-flex.items-center.px-2.py-0.5.rounded.text-xs.font-mono.font-semibold.bg-blue-100.dark:bg-gray-700.text-blue-700.dark:text-blue-300 title
                %span.inline-flex.items-center.px-2.py-0.5.rounded.text-xs.font-mono.font-semibold.bg-blue-100.dark:bg-gray-700.text-blue-700.dark:text-blue-300 body

        / File Upload Area 
        %div{"data-action" => "click->bulk-upload#choose"}
          .border-2.border-dashed.rounded-xl.p-8.text-center.transition-all.duration-300.cursor-pointer.border-gray-300.dark:border-gray-600.bg-white.dark:bg-gray-800.hover:border-blue-400.dark:hover:border-blue-500.hover:bg-blue-50.dark:hover:bg-gray-700{"data-bulk-upload-target" => "dropZone"}

            / Default state
            %div{"data-bulk-upload-target" => "defaultState"}
              .w-12.h-12.rounded-xl.flex.items-center.justify-center.mx-auto.mb-3.bg-gray-100.dark:bg-gray-700
                %svg.w-6.h-6.text-gray-400.dark:text-gray-500{fill: "none", stroke: "currentColor", "stroke-width" => "1.5", viewbox: "0 0 24 24"}
                  %path{d: "M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m6.75 12l-3-3m0 0l-3 3m3-3v6m-1.5-15H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z", "stroke-linecap" => "round", "stroke-linejoin" => "round"}
              %p.text-sm.font-semibold.mb-1.text-gray-700.dark:text-gray-300 Click to choose CSV file
              %p.text-xs.text-gray-400.dark:text-gray-500 Only .csv files are supported

            / Loading state
            %div.hidden{"data-bulk-upload-target" => "loadingState"}
              .w-12.h-12.rounded-xl.flex.items-center.justify-center.mx-auto.mb-3.bg-blue-100.dark:bg-blue-900
                %svg.w-6.h-6.text-blue-500.dark:text-blue-400.animate-spin{fill: "none", viewbox: "0 0 24 24"}
                  %circle.opacity-25{cx: "12", cy: "12", r: "10", stroke: "currentColor", "stroke-width" => "4"}
                  %path.opacity-75{d: "M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z", fill: "currentColor"}
              %p.text-sm.font-semibold.text-blue-600.dark:text-blue-400.mb-1 Reading file...
              %p.text-xs.text-gray-400.dark:text-gray-500 Please wait

            %div.hidden{"data-bulk-upload-target" => "chosenState"}
              .w-12.h-12.rounded-xl.flex.items-center.justify-center.mx-auto.mb-3.bg-green-100.dark:bg-green-900
                %svg.w-6.h-6.text-green-600.dark:text-green-400{fill: "none", stroke: "currentColor", "stroke-width" => "1.5", viewbox: "0 0 24 24"}
                  %path{d: "M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z", "stroke-linecap" => "round", "stroke-linejoin" => "round"}
              %p.text-sm.font-semibold.text-green-700.dark:text-green-400.mb-1 File ready to upload
              %p.text-xs.font-mono.font-semibold.truncate.max-w-xs.mx-auto.px-3.py-1.rounded-lg.mt-1.bg-gray-100.dark:bg-gray-700.text-gray-700.dark:text-gray-300{"data-bulk-upload-target" => "fileNameEl"}
              %p.text-xs.mt-2.text-gray-400.dark:text-gray-500 Click to choose a different file

        %input.hidden{accept: ".csv", name: "file", type: "file", "data-bulk-upload-target" => "fileInput", "data-action" => "change->bulk-upload#handleFile"}/

        / Submit Button
        %button.w-full.flex.items-center.justify-center.gap-2.text-white.font-semibold.py-2.5.rounded-xl.transition-all.duration-200.shadow-md.hover:shadow-lg.bg-blue-600.hover:bg-blue-700.dark:hover:bg-blue-500{type: "submit"}
          %svg.w-4.h-4{fill: "none", stroke: "currentColor", "stroke-width" => "2.5", viewbox: "0 0 24 24"}
            %path{d: "M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5m-13.5-9L12 3m0 0l4.5 4.5M12 3v13.5", "stroke-linecap" => "round", "stroke-linejoin" => "round"}
          Upload Blogs