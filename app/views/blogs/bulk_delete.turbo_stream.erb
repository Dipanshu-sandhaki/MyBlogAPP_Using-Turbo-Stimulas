<% remaining_blogs = current_user.blogs.order(created_at: :desc) %>

<%= turbo_stream.replace "blogs" do %>
  <div id="blogs">
    <% if remaining_blogs.empty? %>
      <div class="mt-12 flex flex-col items-center justify-center py-20 text-center bg-white dark:bg-gray-800 rounded-3xl border border-gray-200 dark:border-gray-700 shadow-sm border-dashed transition-colors">
        <div class="w-20 h-20 rounded-2xl bg-blue-50 dark:bg-gray-700 text-blue-600 dark:text-blue-400 flex items-center justify-center mb-6">
          <svg class="w-10 h-10 stroke-current" fill="none" viewBox="0 0 24 24" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m5.231 13.481L15 17.25m-4.5-15H5.625c-.621 0-1.125.504-1.125 1.125v16.5c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9zm3.75 11.625a2.625 2.625 0 11-5.25 0 2.625 2.625 0 015.25 0z"/>
          </svg>
        </div>
        <h3 class="text-xl font-bold text-gray-900 dark:text-white mb-2">No blogs found</h3>
        <p class="text-gray-500 dark:text-gray-400 max-w-sm">
          Your workspace is empty. Create a new blog or upload via CSV to get started.
        </p>
      </div>
    <% else %>
      <div class="space-y-4">
        <%= render remaining_blogs %>
      </div>
    <% end %>
  </div>
<% end %>

<%= turbo_stream.replace "action_bar" do %>
  <%= render "blogs/action_bar", blogs: remaining_blogs %>
<% end %>

<%= turbo_stream.replace "flash" do %>
  <%= render "shared/flash" %>
<% end %>