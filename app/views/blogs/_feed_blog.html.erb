<div id="feed_blog_<%= blog.id %>"
     class="bg-white dark:bg-gray-900 rounded-2xl border border-gray-200 dark:border-gray-800
            shadow-sm p-6 hover:shadow-md dark:hover:shadow-gray-900 transition-all duration-200">

  <!-- AUTHOR ROW -->
  <div class="flex items-center justify-between mb-4">
    <div class="flex items-center gap-3">
      <div class="w-10 h-10 rounded-full overflow-hidden bg-blue-600
                  flex items-center justify-center shrink-0 border border-gray-100 dark:border-gray-700">
        <% if blog.user.avatar.attached? %>
          <%= image_tag url_for(blog.user.avatar), class: "w-full h-full object-cover" %>
        <% else %>
          <span class="text-white text-sm font-bold"><%= blog.user.email[0].upcase %></span>
        <% end %>
      </div>
      <div>
        <p class="text-sm font-bold text-gray-900 dark:text-white"><%= blog.user.email.split("@").first %></p>
        <p class="text-xs text-gray-400 dark:text-gray-500"><%= time_ago_in_words(blog.created_at) %> ago</p>
      </div>
    </div>

    <% if current_user != blog.user %>
      <% if current_user.following?(blog.user) %>
        <%= button_to unfollow_user_path(blog.user), method: :delete,
            class: "text-xs border border-gray-300 dark:border-gray-600 text-gray-600 dark:text-gray-300
                    px-4 py-1.5 rounded-full hover:bg-gray-100 dark:hover:bg-gray-800 transition font-medium" do %>
          ✓ Following
        <% end %>
      <% else %>
        <%= button_to follow_user_path(blog.user), method: :post,
            class: "text-xs bg-blue-600 text-white px-4 py-1.5
                    rounded-full hover:bg-blue-700 transition font-medium" do %>
          + Follow
        <% end %>
      <% end %>
    <% end %>
  </div>

  <!-- COVER IMAGE -->
  <% if blog.cover_image.attached? %>
    <%= image_tag blog.cover_image,
        class: "w-full max-h-52 object-cover rounded-xl mb-4 border border-gray-200 dark:border-gray-700" %>
  <% end %>

  <!-- BLOG TITLE -->
  <h3 class="text-xl font-bold text-gray-900 dark:text-white mb-1"><%= blog.title %></h3>
  <div class="h-[2px] bg-blue-500/50 w-10 rounded-full mb-3"></div>

  <!-- BLOG BODY -->
  <% plain_text = blog.content.to_plain_text %>
  <% word_limit = 40 %>
  <% words = plain_text.split %>
  <% is_long = words.length > word_limit %>

  <div class="text-sm leading-relaxed">
    <!-- Short preview -->
    <div id="short_<%= blog.id %>" class="<%= is_long ? '' : 'hidden' %> text-gray-600 dark:text-gray-400 break-words">
      <%= words.first(word_limit).join(" ") %>...
      <button onclick="document.getElementById('short_<%= blog.id %>').classList.add('hidden');
                       document.getElementById('full_<%= blog.id %>').classList.remove('hidden')"
              class="text-blue-500 hover:text-blue-400 font-medium ml-1">
        See more
      </button>
    </div>

    <!-- Full content -->
    <div id="full_<%= blog.id %>" class="<%= is_long ? 'hidden' : '' %> trix-content text-gray-600 dark:text-gray-300 break-words">
      <%= raw blog.content&.body&.to_html %>
      <% if is_long %>
        <button onclick="document.getElementById('full_<%= blog.id %>').classList.add('hidden');
                         document.getElementById('short_<%= blog.id %>').classList.remove('hidden')"
                class="text-blue-500 hover:text-blue-400 font-medium ml-1 block mt-2">
          See less
        </button>
      <% end %>
    </div>

  </div>

  <!-- LIKE + COMMENT -->
  <div class="mt-4 pt-3 border-t border-gray-100 dark:border-gray-800 flex items-center gap-5">
    <div id="like_section_<%= blog.id %>">
      <%= render "likes/like_button", blog: blog, current_user: current_user %>
    </div>
    <div class="flex items-center gap-1.5 text-sm text-gray-500 dark:text-gray-400">
      <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none"
           viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round"
          d="M8 10h.01M12 10h.01M16 10h.01M21 12c0 4.418-4.03 8-9 8
             a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72
             C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" />
      </svg>
      <span><%= blog.comments.count %></span>
    </div>
  </div>

  <!-- COMMENTS -->
  <div class="mt-4" id="comments_<%= blog.id %>">
    <%= render "comments/comments", blog: blog, current_user: current_user %>
  </div>

</div>