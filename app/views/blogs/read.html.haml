.min-h-screen.bg-white.dark:bg-gray-900.transition-colors.duration-300

  / Top Nav Bar 
  .sticky.top-0.z-40.bg-white.dark:bg-gray-900.border-b.border-gray-200.dark:border-gray-700
    .max-w-5xl.mx-auto.px-4.sm:px-6.py-3.flex.items-center.justify-between
      = link_to root_path, class: "inline-flex items-center gap-2 text-sm font-semibold text-gray-600 dark:text-gray-300 hover:text-blue-600 dark:hover:text-blue-400 transition-colors group" do
        %svg.w-4.h-4.transition-transform.group-hover:-translate-x-0.5{fill: "none", stroke: "currentColor", "stroke-width" => "2.5", viewbox: "0 0 24 24"}
          %path{d: "M15 19l-7-7 7-7", "stroke-linecap" => "round", "stroke-linejoin" => "round"}
        Back to Feed
      .flex.items-center.gap-2.text-xs.text-gray-500.dark:text-gray-400.font-medium
        %svg.w-3.5.h-3.5{fill: "none", stroke: "currentColor", "stroke-width" => "2", viewbox: "0 0 24 24"}
          %path{d: "M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z", "stroke-linecap" => "round", "stroke-linejoin" => "round"}
        = [1, (@blog.content.to_plain_text.split.length / 200.0).ceil].max
        min read

  .max-w-5xl.mx-auto.px-4.sm:px-6.py-10.flex.gap-8.items-start

    / ARTICLE 
    %article.flex-1.min-w-0

      / Cover Image
      - if @blog.cover_image.attached?
        .mb-8.rounded-2xl.overflow-hidden.shadow-lg
          = image_tag @blog.cover_image, class: "w-full max-h-80 object-cover"

      / Author Row
      .flex.items-center.justify-between.mb-6
        .flex.items-center.gap-3
          .w-11.h-11.rounded-full.overflow-hidden.shrink-0.ring-2.ring-gray-200.dark:ring-gray-600{style: "background: linear-gradient(135deg, #3b82f6, #4f46e5);"}
            - if @blog.user.avatar.attached?
              = image_tag url_for(@blog.user.avatar), class: "w-full h-full object-cover"
            - else
              .w-full.h-full.flex.items-center.justify-center
                %span.text-white.text-sm.font-extrabold= @blog.user.email[0].upcase
          %div
            %p.text-sm.font-extrabold.text-gray-900.dark:text-white.leading-tight
              = @blog.user.email.split("@").first
            %p.text-xs.text-gray-500.dark:text-gray-400.leading-tight{class: "mt-0.5"}
              = time_ago_in_words(@blog.created_at)
              ago
        - if current_user != @blog.user
          - if current_user.following?(@blog.user)
            = button_to unfollow_user_path(@blog.user), method: :delete, class: "text-xs border border-gray-300 dark:border-gray-600 text-gray-700 dark:text-gray-300 px-4 py-1.5 rounded-lg font-semibold hover:bg-gray-100 dark:hover:bg-gray-700 transition-all" do
              ✓ Following
          - else
            = button_to follow_user_path(@blog.user), method: :post, class: "text-xs bg-blue-600 hover:bg-blue-700 text-white px-4 py-1.5 rounded-lg font-bold shadow-sm transition-all" do
              \+ Follow

      / Title
      %h1.text-3xl.font-extrabold.text-gray-900.dark:text-white.leading-tight.mb-3.tracking-tight{class: "sm:text-4xl"}
        = @blog.title
      .w-12.bg-blue-600.rounded-full.mb-8{class: "h-[3px]"}

      .trix-content.max-w-none.leading-relaxed.text-base.text-gray-800.dark:text-gray-100{class: "[&_*]:!color-inherit"}
        = raw @blog.content&.body&.to_html

      / Like + Comment bar
      .mt-10.pt-6.border-t.border-gray-200.dark:border-gray-700.flex.items-center.gap-6
        %div{id: "like_section_#{@blog.id}"}
          = render "likes/like_button", blog: @blog, current_user: current_user

        = turbo_frame_tag "comment_count_#{@blog.id}" do
          .flex.items-center.gap-2.text-sm.font-semibold.text-gray-500.dark:text-gray-400
            %svg.w-4.h-4{fill: "none", stroke: "currentColor", "stroke-width" => "2", viewbox: "0 0 24 24"}
              %path{d: "M8 10h.01M12 10h.01M16 10h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z", "stroke-linecap" => "round", "stroke-linejoin" => "round"}
            %span= @blog.comments.count
            comments

      / Comments Section
      .mt-8
        %h2.text-xl.font-extrabold.text-gray-900.dark:text-white.mb-5{id: "comments_heading_#{@blog.id}"}
          - if @blog.comments.count.zero?
            No comments yet — be the first!
          - else
            = "#{@blog.comments.count} #{"Comment".pluralize(@blog.comments.count)}"

        %div{id: "comment_form_#{@blog.id}"}
          = render "comments/form", blog: @blog, comment: Comment.new

        .mt-4.space-y-3{id: "comment_list_#{@blog.id}"}
          - @comments.each do |comment|
            = render "comments/comment", comment: comment, blog: @blog, current_user: current_user

    / sidebar
    .w-64.shrink-0.hidden.lg:block
      .sticky.top-24.space-y-4

        / Author Card
        .bg-gray-50.dark:bg-gray-800.rounded-2xl.border.border-gray-200.dark:border-gray-700.shadow-sm.p-5
          %p.text-xs.font-extrabold.text-gray-400.dark:text-gray-500.uppercase.tracking-widest.mb-3
            Written by
          .flex.items-center.gap-3.mb-4
            .w-12.h-12.rounded-full.overflow-hidden.shrink-0{style: "background: linear-gradient(135deg, #3b82f6, #4f46e5);"}
              - if @blog.user.avatar.attached?
                = image_tag url_for(@blog.user.avatar), class: "w-full h-full object-cover"
              - else
                .w-full.h-full.flex.items-center.justify-center
                  %span.text-white.font-extrabold= @blog.user.email[0].upcase
            %div
              %p.text-sm.font-extrabold.text-gray-900.dark:text-white
                = @blog.user.email.split("@").first
              %p.text-xs.text-gray-500.dark:text-gray-400.mt-0.5
                = pluralize(@blog.user.blogs.published.count, "post")
          - if current_user != @blog.user
            - if current_user.following?(@blog.user)
              = button_to unfollow_user_path(@blog.user), method: :delete, class: "w-full text-xs border border-gray-300 dark:border-gray-600 text-gray-700 dark:text-gray-300 py-2 rounded-xl font-semibold hover:bg-gray-100 dark:hover:bg-gray-700 transition-all" do
                ✓ Following
            - else
              = button_to follow_user_path(@blog.user), method: :post, class: "w-full text-xs bg-blue-600 hover:bg-blue-700 text-white py-2 rounded-xl font-bold shadow-sm transition-all" do
                \+ Follow

        / Article Stats
        .bg-gray-50.dark:bg-gray-800.rounded-2xl.border.border-gray-200.dark:border-gray-700.shadow-sm.p-5.space-y-3
          %p.text-xs.font-extrabold.text-gray-400.dark:text-gray-500.uppercase.tracking-widest.mb-1
            Article Info
          .flex.items-center.justify-between
            %span.text-xs.font-semibold.text-gray-500.dark:text-gray-400 Published
            %span.text-xs.font-bold.text-gray-900.dark:text-white
              = @blog.created_at.strftime("%b %d, %Y")
          .w-full.h-px.bg-gray-200.dark:bg-gray-700
          .flex.items-center.justify-between
            %span.text-xs.font-semibold.text-gray-500.dark:text-gray-400 Read time
            %span.text-xs.font-bold.text-gray-900.dark:text-white
              = [1, (@blog.content.to_plain_text.split.length / 200.0).ceil].max
              min
          .w-full.h-px.bg-gray-200.dark:bg-gray-700
          .flex.items-center.justify-between
            %span.text-xs.font-semibold.text-gray-500.dark:text-gray-400 Comments
            %span.text-xs.font-bold.text-gray-900.dark:text-white{id: "sidebar_comment_count_#{@blog.id}"}
              = @blog.comments.count
          .w-full.h-px.bg-gray-200.dark:bg-gray-700
          .flex.items-center.justify-between
            %span.text-xs.font-semibold.text-gray-500.dark:text-gray-400 Likes
            %span.text-xs.font-bold.text-gray-900.dark:text-white
              = @blog.likes.count