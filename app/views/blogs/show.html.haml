= turbo_frame_tag "modal" do
  / Close button
  .flex.justify-end.px-4.pt-4
    %button.p-1.5.rounded-lg.text-gray-400.hover:text-gray-700.dark:hover:text-white.hover:bg-gray-100.dark:hover:bg-gray-700.transition{"data-action" => "click->modal#close", type: "button"}
      %svg.w-5.h-5{fill: "none", stroke: "currentColor", "stroke-width" => "2.5", viewbox: "0 0 24 24"}
        %path{d: "M6 18L18 6M6 6l12 12", "stroke-linecap" => "round", "stroke-linejoin" => "round"}

  .px-6.pb-6

    / Cover Image
    - if @blog.cover_image.attached?
      = image_tag @blog.cover_image, class: "w-full h-56 object-cover rounded-xl mb-6 border border-gray-100 dark:border-gray-700"

    / Status badge row
    .flex.items-center.gap-2.mb-4
      %span{class: "#{@blog.published? ? 'bg-green-100 text-green-700 dark:bg-green-900/40 dark:text-green-400' : 'bg-yellow-100 text-yellow-700 dark:bg-yellow-900/40 dark:text-yellow-400'} px-2.5 py-1 text-xs font-bold uppercase tracking-wider rounded-md"}
        = @blog.status
      %span.text-xs.text-gray-400.dark:text-gray-500.font-medium
        = time_ago_in_words(@blog.created_at)
        ago

    / Author row
    .flex.items-center.gap-3.mb-5.pb-5.border-b.border-gray-100.dark:border-gray-700
      .w-10.h-10.rounded-full.overflow-hidden.shrink-0.ring-2.ring-gray-100.dark:ring-gray-700{style: "background: linear-gradient(135deg, #3b82f6, #4f46e5);"}
        - if @blog.user.avatar.attached?
          = image_tag url_for(@blog.user.avatar), class: "w-full h-full object-cover"
        - else
          .w-full.h-full.flex.items-center.justify-center
            %span.text-white.text-sm.font-extrabold= @blog.user.email[0].upcase
      %div
        %p.text-sm.font-bold.text-gray-900.dark:text-white.leading-tight
          = @blog.user.email.split("@").first
        %p.text-xs.text-gray-400.dark:text-gray-500.leading-tight{class: "mt-0.5"}
          = @blog.created_at.strftime("%B %d, %Y")

    / Title
    %h1.text-2xl.sm:text-3xl.font-extrabold.text-gray-900.dark:text-white.leading-tight.break-words.mb-2
      = @blog.title
    .w-10.bg-blue-600.rounded-full.mb-6{class: "h-[3px]"}

    / Full content
    .trix-content.text-gray-700.dark:text-gray-300.leading-relaxed.break-words
      = raw @blog.content&.body&.to_html

:css
  .trix-content {
    font-size: 1.0625rem;
    line-height: 1.8;
  }
  @media (min-width: 640px) {
    .trix-content { font-size: 1.125rem; }
  }
  .trix-content h1 { font-size: 1.5em; font-weight: 800; margin: 1em 0 0.5em; }
  .trix-content h2 { font-size: 1.25em; font-weight: 700; margin: 1em 0 0.5em; }
  .trix-content p  { margin-bottom: 1em; }
  .trix-content a  { color: #4f46e5; text-decoration: underline; word-break: break-all; }
  .dark .trix-content a { color: #818cf8; }
  .trix-content ul { list-style: disc; padding-left: 1.5em; margin-bottom: 1em; }
  .trix-content ol { list-style: decimal; padding-left: 1.5em; margin-bottom: 1em; }
  .trix-content blockquote { border-left: 3px solid #4f46e5; padding-left: 1em; color: #6b7280; margin: 1em 0; }