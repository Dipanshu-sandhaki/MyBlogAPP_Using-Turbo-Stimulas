<turbo-frame id="modal">
  <div class="bg-gray-900 text-white px-5 py-4 flex justify-between items-center border-b border-gray-700">
    <h2 class="text-xs font-semibold uppercase tracking-widest text-gray-400">View Blog</h2>
    <button type="button" data-action="click->modal#close"
            class="text-gray-400 hover:text-red-400 text-xl font-bold leading-none">
      &times;
    </button>
  </div>

  <% if @blog.cover_image.attached? %>
    <%= image_tag @blog.cover_image, class: "w-full max-h-64 object-cover" %>
  <% end %>

  <div class="bg-gray-900 p-6 space-y-4">
    <h1 class="text-2xl font-bold text-white"><%= @blog.title %></h1>
    <span class="inline-block text-xs text-gray-500 bg-gray-800 px-3 py-1 rounded-full">
      <%= time_ago_in_words(@blog.created_at) %> ago
    </span>

    <div class="trix-content text-gray-300 text-sm leading-relaxed pt-2">
      <%= raw @blog.content&.body&.to_html %>
    </div>
  </div>
</turbo-frame>