<turbo-frame id="modal">

  <!-- HEADER -->
  <div class="bg-gray-900 text-white px-5 py-4 rounded-t-xl flex justify-between items-center">

    <h2 class="text-lg font-semibold tracking-wide text-gray-300 uppercase">
      View Blog
    </h2>

    <button
      type="button"
      data-action="click->modal#close"
      class="text-gray-400 hover:text-red-400 text-xl font-bold transition">
      &times;
    </button>
  </div>

  <!-- BODY -->
  <div class="bg-white px-6 py-4">

    <!-- TITLE -->
    <div class="mb-2">
      <h1 class="text-2xl font-bold text-gray-900 leading-snug">
        <%= @blog.title %>
      </h1>

      <div class="mt-1">
        <span class="inline-block bg-gray-100 text-gray-600 text-xs px-3 py-1 rounded-full">
          <%= time_ago_in_words(@blog.created_at) %> ago
        </span>
      </div>
    </div>

    <!-- DIVIDER -->
    <div class="border-t border-gray-200 mb-3"></div>

    <!-- CONTENT BOX -->
    <div class="bg-white border border-gray-500 rounded-xl px-4 py-3 shadow-sm">

  <div class="text-gray-800 text-[15px] leading-normal break-all text-justify">
  <%= simple_format(@blog.body.strip) %>
</div>

</div>

    </div>

  </div>

</turbo-frame>