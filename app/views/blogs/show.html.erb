<turbo-frame id="modal">
  <div class="relative bg-white dark:bg-gray-900 rounded-3xl overflow-hidden flex flex-col shadow-2xl" id="blog-modal-container">
    
    <div class="sticky top-0 z-20 flex justify-between items-center px-6 py-4 bg-white/95 dark:bg-gray-900/95 backdrop-blur-md border-b border-gray-200 dark:border-gray-800">
      <div class="flex items-center gap-3">
        <span class="<%= @blog.published? ? 'badge-published' : 'badge-draft' %> px-2.5 py-1 text-xs font-bold uppercase tracking-wider rounded-md">
  <%= @blog.status %>
</span>
        <span class="text-sm font-medium text-gray-500 dark:text-gray-400">
          <%= time_ago_in_words(@blog.created_at) %> ago
        </span>
      </div>
      
      <button type="button" onclick="closeBlogModal()" class="p-2 rounded-full bg-gray-100 dark:bg-gray-800 text-gray-500 dark:text-gray-400 hover:bg-red-100 hover:text-red-600 dark:hover:bg-red-900/30 dark:hover:text-red-400 transition-colors">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M6 18L18 6M6 6l12 12"></path>
        </svg>
      </button>
    </div>

    <div class="p-6 sm:p-8 relative">
      <% if @blog.cover_image.attached? %>
        <%= image_tag @blog.cover_image, class: "w-full h-64 sm:h-80 object-cover rounded-2xl mb-8 shadow-sm border border-gray-100 dark:border-gray-800" %>
      <% end %>

      <h1 class="text-3xl sm:text-4xl font-extrabold text-gray-900 dark:text-white mb-6 leading-tight break-words">
        <%= @blog.title %>
      </h1>

      <div id="blog-content-wrapper" class="relative max-h-[150px] overflow-hidden transition-all duration-500 ease-in-out">
        
        <div id="blog-inner-content" class="trix-content text-justify pb-4 break-words">
          <%= raw @blog.content&.body&.to_html %>
        </div>
        
        <div id="blog-content-fader" class="absolute bottom-0 left-0 right-0 h-20 bg-gradient-to-t from-white dark:from-gray-900 to-transparent pointer-events-none transition-opacity duration-300"></div>
      </div>

      <div id="see-more-container" class="mt-8 flex justify-center hidden">
        <button id="blog-read-more-btn" onclick="toggleReadMore()" class="inline-flex items-center gap-2 px-6 py-2.5 rounded-full text-sm font-bold bg-gray-100 dark:bg-gray-800 text-gray-900 dark:text-white border border-gray-200 dark:border-gray-700 hover:bg-gray-200 dark:hover:bg-gray-700 transition-all shadow-sm group">
          <span>See More</span>
          <svg id="read-more-icon" class="w-4 h-4 transition-transform duration-300 group-hover:translate-y-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 9l-7 7-7-7"></path>
          </svg>
        </button>
      </div>
    </div>
  </div>

  <style>
    #blog-inner-content {
      color: #111827; 
      font-size: 1rem;
      line-height: 1.75;
    }
    
    .dark #blog-inner-content {
      color: #e5e7eb; 
    }
    
    @media (min-width: 640px) {
      #blog-inner-content {
        font-size: 1.125rem; 
      }
    }

    #blog-inner-content div,
    #blog-inner-content p,
    #blog-inner-content span,
    #blog-inner-content li {
      font-size: inherit;
      color: inherit;
      line-height: inherit;
    }

    #blog-inner-content h1 {
      font-size: 1.5em;
      font-weight: bold;
      margin-top: 1em;
      margin-bottom: 0.5em;
    }

    #blog-inner-content a {
      color: #4f46e5;
      text-decoration: underline;
    }

    .dark #blog-inner-content a {
      color: #818cf8;
    }
  </style>

  <script>
    // Force hide modal and clear content
    window.closeBlogModal = function() {
      const globalModal = document.querySelector('[data-modal-target="modal"]');
      if (globalModal) {
        globalModal.classList.add('hidden');
      }
      document.getElementById('modal').innerHTML = '';
    };

    // Initialize See More
    (function() {
      const wrapper = document.getElementById('blog-content-wrapper');
      const innerContent = document.getElementById('blog-inner-content');
      const container = document.getElementById('see-more-container');
      const fader = document.getElementById('blog-content-fader');

      if (!wrapper || !innerContent || !container) return;

      function checkHeight() {
        const realHeight = innerContent.offsetHeight;

        if (realHeight > 160) {
          container.classList.remove('hidden'); 
        } else {
          wrapper.classList.remove('max-h-[150px]');
          wrapper.style.maxHeight = 'none';
          if(fader) fader.style.display = 'none';
          container.classList.add('hidden');
        }
      }

      const observer = new ResizeObserver((entries) => {
        for (let entry of entries) {
          if (entry.contentRect.height > 0) {
            checkHeight();
            observer.disconnect();
          }
        }
      });

      observer.observe(innerContent);
      
      // Fallback
      setTimeout(checkHeight, 100);
    })();

    window.toggleReadMore = function() {
      const wrapper = document.getElementById('blog-content-wrapper');
      const innerContent = document.getElementById('blog-inner-content');
      const fader = document.getElementById('blog-content-fader');
      const btnText = document.querySelector('#blog-read-more-btn span');
      const icon = document.getElementById('read-more-icon');

      const realHeight = innerContent.offsetHeight;

      if (wrapper.classList.contains('max-h-[150px]')) {
        wrapper.style.maxHeight = realHeight + "px";
        wrapper.classList.remove('max-h-[150px]');
        if(fader) fader.style.opacity = '0';
        if(btnText) btnText.textContent = 'See Less';
        if(icon) {
          icon.classList.add('rotate-180');
          icon.classList.remove('group-hover:translate-y-0.5');
          icon.classList.add('group-hover:-translate-y-0.5');
        }

        setTimeout(() => { wrapper.style.maxHeight = 'none'; }, 500);
      } else {
        wrapper.style.maxHeight = realHeight + "px";
        void wrapper.offsetHeight; 

        wrapper.classList.add('max-h-[150px]');
        wrapper.style.maxHeight = null;
        if(fader) fader.style.opacity = '1';
        if(btnText) btnText.textContent = 'See More';
        if(icon) {
          icon.classList.remove('rotate-180');
          icon.classList.remove('group-hover:-translate-y-0.5');
          icon.classList.add('group-hover:translate-y-0.5');
        }

        const scrollArea = document.getElementById('global-modal-scroll');
        if (scrollArea) scrollArea.scrollTo({top: 0, behavior: 'smooth'});
      }
    };
  </script>
</turbo-frame>