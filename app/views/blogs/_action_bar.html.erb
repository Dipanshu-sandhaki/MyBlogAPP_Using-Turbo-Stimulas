<div id="action_bar" class="mb-6">
  <% if blogs.empty? %>
    <div class="flex justify-center gap-4 mt-6">
      <%= link_to new_blog_path,
          class: "inline-flex items-center gap-2 bg-blue-600 hover:bg-blue-700 dark:bg-blue-600 dark:hover:bg-blue-500 text-white px-6 py-2.5 rounded-xl text-sm font-bold shadow-sm transition-all" do %>
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 4v16m8-8H4"/></svg>
        Create Blog
      <% end %>

      <%= link_to bulk_upload_blogs_path,
          data: { turbo_frame: "modal" },
          class: "inline-flex items-center gap-2 bg-gray-100 hover:bg-gray-200 dark:bg-gray-800 dark:hover:bg-gray-700 text-gray-900 dark:text-white border border-gray-200 dark:border-gray-700 px-6 py-2.5 rounded-xl text-sm font-bold shadow-sm transition-all" do %>
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12"/></svg>
        Bulk Upload
      <% end %>
    </div>
  <% else %>
    <div class="flex items-center justify-between">

      <label data-bulk-select-target="selectAllLabel"
             class="<%= blogs.size > 1 ? '' : 'hidden' %> flex items-center gap-3 text-sm font-bold cursor-pointer text-gray-700 dark:text-gray-300 hover:text-blue-600 dark:hover:text-blue-400 transition-colors">
        
        <input type="checkbox"
               data-bulk-select-target="selectAllCheckbox"
               data-action="change->bulk-select#toggleAll"
               class="w-5 h-5 rounded border-gray-300 dark:border-gray-600 text-blue-600 focus:ring-blue-500 bg-gray-50 dark:bg-gray-900 transition-all cursor-pointer">
        Select All
      </label>

      <div class="flex items-center gap-3 ml-auto">
  <button data-bulk-select-target="deleteBtn"
          data-action="bulk-select#deleteSelected"
          class="hidden inline-flex items-center gap-2 bg-red-50 hover:bg-red-100 dark:bg-gray-800 dark:hover:bg-gray-700 text-red-600 dark:text-red-500 border border-transparent dark:border-red-900/30 px-4 py-2 rounded-xl text-sm font-bold transition-all shadow-sm">
    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
    Delete Selected
    
    <%# Updated Count Badge Target %>
    <span data-bulk-select-target="count" class="ml-1 px-2 py-0.5 bg-red-100 dark:bg-gray-900 text-red-700 dark:text-red-500 rounded-md text-xs font-extrabold hidden">
      0
    </span>
  </button>

        <%= link_to new_blog_path,
            class: "inline-flex items-center gap-1.5 bg-blue-600 hover:bg-blue-700 dark:bg-blue-600 dark:hover:bg-blue-500 text-white px-4 py-2 rounded-xl text-sm font-bold shadow-sm transition-all" do %>
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 4v16m8-8H4"/></svg>
          Create
        <% end %>

        <%= link_to bulk_upload_blogs_path,
            data: { turbo_frame: "modal" },
            class: "inline-flex items-center gap-1.5 bg-gray-100 hover:bg-gray-200 dark:bg-gray-700 dark:hover:bg-gray-600 text-gray-900 dark:text-white px-4 py-2 rounded-xl text-sm font-bold shadow-sm transition-all" do %>
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12"/></svg>
          Upload
        <% end %>
      </div>
    </div>
  <% end %>
</div>