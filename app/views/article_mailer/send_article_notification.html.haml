%table{style: "width: 100%; border-collapse: collapse; font-family: Arial, sans-serif;", cellpadding: "0", cellspacing: "0"}
  %tr
    %td{style: "padding: 20px 0; background-color: #f1f5f9;"}
      %table{style: "max-width: 600px; margin: 0 auto; background-color: #ffffff; border: 1px solid #cbd5e1;", cellpadding: "0", cellspacing: "0", width: "600"}

        / HEADER
        %tr
          %td{style: "background-color: #2563eb; padding: 32px 30px; text-align: center;"}
            %h1{style: "color: #ffffff; margin: 0 0 6px; font-size: 26px; font-weight: 800; letter-spacing: -0.5px;"}
              TurboBlog
            %p{style: "color: #bfdbfe; margin: 0; font-size: 13px; font-weight: 500;"}
              WRITE &bull; SHARE &bull; CONNECT

        / GREETING
        %tr
          %td{style: "padding: 30px 30px 0;"}
            %p{style: "font-size: 17px; font-weight: 700; color: #111827; margin: 0 0 8px;"}
              = "Hi #{@recipient_name}!"
            %p{style: "font-size: 14px; color: #4b5563; margin: 0; line-height: 1.6;"}
              Someone shared an article with you on TurboBlog. We think you will enjoy it!

        / ARTICLE CARD
        %tr
          %td{style: "padding: 20px 30px;"}
            %table{style: "width: 100%; border-collapse: collapse; background-color: #f8fafc; border: 2px solid #2563eb;", cellpadding: "0", cellspacing: "0"}
              %tr
                %td{style: "background-color: #2563eb; padding: 8px 16px;"}
                  %p{style: "color: #ffffff; font-size: 10px; font-weight: 700; text-transform: uppercase; letter-spacing: 2px; margin: 0;"}
                    Featured Article
              %tr
                %td{style: "padding: 20px;"}
                  %h2{style: "font-size: 20px; font-weight: 800; color: #111827; margin: 0 0 12px; line-height: 1.4;"}
                    = @blog.title
                  %p{style: "font-size: 14px; color: #374151; line-height: 1.7; margin: 0 0 20px;"}
                    = truncate(@blog.content.to_plain_text, length: 200)

                  %table{style: "width: 100%; border-collapse: collapse; border-top: 1px solid #e2e8f0; margin-bottom: 20px;", cellpadding: "0", cellspacing: "0"}
                    %tr
                      %td{style: "padding-top: 14px; font-size: 12px; color: #64748b; font-weight: 600;"}
                        = "By: #{@blog.user.email.split('@').first}"
                      %td{style: "padding-top: 14px; font-size: 12px; color: #64748b; font-weight: 600; text-align: center;"}
                        = @blog.created_at.strftime('%b %d, %Y')
                      %td{style: "padding-top: 14px; font-size: 12px; color: #64748b; font-weight: 600; text-align: right;"}
                        = "#{[1, (@blog.content.to_plain_text.split.length / 200.0).ceil].max} min read"

                  %table{style: "border-collapse: collapse;", cellpadding: "0", cellspacing: "0"}
                    %tr
                      %td{style: "background-color: #2563eb; padding: 0;"}
                        %a{href: read_blog_url(@blog), style: "display: inline-block; background-color: #2563eb; color: #ffffff; padding: 13px 28px; text-decoration: none; font-weight: 700; font-size: 14px; letter-spacing: 0.3px;"}
                          Read Full Article &rarr;

        / DIVIDER
        %tr
          %td{style: "padding: 0 30px;"}
            %table{style: "width: 100%; border-collapse: collapse;", cellpadding: "0", cellspacing: "0"}
              %tr
                %td{style: "border-top: 1px solid #e2e8f0; font-size: 0; height: 1px;"}

        / FOOTER
        %tr
          %td{style: "background-color: #f8fafc; padding: 24px 30px; border-top: 3px solid #2563eb;"}
            %table{style: "width: 100%; border-collapse: collapse;", cellpadding: "0", cellspacing: "0"}
              %tr
                %td{style: "text-align: center;"}
                  %p{style: "font-size: 13px; font-weight: 700; color: #2563eb; margin: 0 0 6px;"}
                    TurboBlog
                  %p{style: "font-size: 12px; color: #596679; margin: 0 0 4px; line-height: 1.6;"}
                    You received this email because someone shared an article with you.
                  %p{style: "font-size: 12px; color: #596271; margin: 0;"}
                    &copy; 2026 TurboBlog. All rights reserved.