- if @comment.parent_id.present?
  = turbo_stream.prepend "replies_#{@comment.parent_id}" do
    = render "comments/comment", comment: @comment, blog: @blog, current_user: current_user

  = turbo_stream.replace "reply_form_#{@replied_form_id}" do
    .hidden.mt-2{id: "reply_form_#{@replied_form_id}"}
      .flex.items-start.gap-2
        .w-7.h-7.rounded-full.overflow-hidden.bg-blue-600.flex.items-center.justify-center.shrink-0
          - if current_user.avatar.attached?
            = image_tag url_for(current_user.avatar), class: "w-full h-full object-cover"
          - else
            %span.text-white.text-xs.font-bold= current_user.email[0].upcase
        = form_with url: blog_comments_path(@blog), scope: :comment, data: { turbo_stream: true }, class: "flex-1 flex gap-2" do |f|
          = f.hidden_field :parent_id, value: @replied_form_id
          = f.text_field :body, value: "", placeholder: "Write a reply...", class: "flex-1 border border-gray-300 dark:border-gray-600 bg-gray-100 dark:bg-gray-700 text-gray-900 dark:text-white placeholder-gray-400 dark:placeholder-gray-500 rounded-full px-4 py-1.5 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500"
          = f.submit "Reply", class: "bg-blue-600 text-white text-sm px-4 py-1.5 rounded-full hover:bg-blue-700 transition cursor-pointer"

- else
  / TOP-LEVEL COMMENT
  = turbo_stream.prepend "comment_list_#{@blog.id}" do
    = render "comments/comment", comment: @comment, blog: @blog, current_user: current_user

  = turbo_stream.replace "comment_form_#{@blog.id}" do
    %div{id: "comment_form_#{@blog.id}"}
      = render "comments/form", blog: @blog, comment: Comment.new

/ COUNT UPDATES
= turbo_stream.replace "comment_count_#{@blog.id}" do
  = turbo_frame_tag "comment_count_#{@blog.id}" do
    .flex.items-center.gap-2.text-sm.font-semibold.text-gray-500.dark:text-gray-400
      %svg.w-4.h-4{fill: "none", stroke: "currentColor", "stroke-width" => "2", viewbox: "0 0 24 24"}
        %path{d: "M8 10h.01M12 10h.01M16 10h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z", "stroke-linecap" => "round", "stroke-linejoin" => "round"}
      %span= @blog.comments.count
      comments

= turbo_stream.replace "comments_heading_#{@blog.id}" do
  %h2.text-xl.font-extrabold.text-gray-900.dark:text-white.mb-5{id: "comments_heading_#{@blog.id}"}
    = "#{@blog.comments.count} #{"Comment".pluralize(@blog.comments.count)}"

= turbo_stream.replace "sidebar_comment_count_#{@blog.id}" do
  %span.text-xs.font-bold.text-gray-900.dark:text-white{id: "sidebar_comment_count_#{@blog.id}"}
    = @blog.comments.count