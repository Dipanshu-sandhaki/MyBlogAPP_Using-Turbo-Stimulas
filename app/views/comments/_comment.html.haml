.flex.items-start.gap-3{"data-controller" => "comment-edit", id: dom_id(comment)}
  / AVATAR
  .w-8.h-8.rounded-full.overflow-hidden.bg-blue-600.flex.items-center.justify-center.shrink-0
    - if comment.user.avatar.attached?
      = image_tag url_for(comment.user.avatar), class: "w-full h-full object-cover"
    - else
      %span.text-white.text-xs.font-bold= comment.user.email[0].upcase

  .flex-1
    / COMMENT VIEW
    .bg-gray-100.dark:bg-gray-700.rounded-2xl.px-4.py-2.5{"data-comment-edit-target" => "view"}
      .flex.items-center.justify-between.mb-1
        %span.text-sm.font-bold.text-gray-900.dark:text-white
          = comment.user.email.split("@").first
        .flex.items-center.gap-2
          %span.text-xs.text-gray-400.dark:text-gray-500
            = time_ago_in_words(comment.created_at)
            ago
          - if current_user == comment.user
            %button.text-blue-500.hover:text-blue-400.transition{"data-action" => "click->comment-edit#showEdit", title: "Edit"}
              %svg.w-3.5.h-3.5{fill: "none", stroke: "currentColor", "stroke-width" => "2.5", viewbox: "0 0 24 24"}
                %path{d: "M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z", "stroke-linecap" => "round", "stroke-linejoin" => "round"}
            = button_to blog_comment_path(blog, comment), method: :delete, data: { turbo_stream: true }, class: "text-red-500 hover:text-red-400 transition", title: "Delete" do
              %svg.w-3.5.h-3.5{fill: "none", stroke: "currentColor", "stroke-width" => "2.5", viewbox: "0 0 24 24"}
                %path{d: "M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16", "stroke-linecap" => "round", "stroke-linejoin" => "round"}

      %p.text-sm.text-gray-800.dark:text-gray-100.break-words
        = comment.body

    / COMMENT EDIT FORM
    - if current_user == comment.user
      .hidden{"data-comment-edit-target" => "edit"}
        = form_with url: blog_comment_path(blog, comment), method: :patch, scope: :comment, data: { turbo_stream: true }, class: "flex gap-2 mt-1" do |f|
          = f.text_field :body, value: comment.body, class: "flex-1 border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 text-gray-900 dark:text-white rounded-full px-4 py-1.5 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500"
          .flex.gap-1
            = f.submit "Save", class: "bg-blue-600 text-white text-sm px-3 py-1.5 rounded-full hover:bg-blue-700 transition cursor-pointer"
            %button.bg-gray-200.dark:bg-gray-700.text-gray-600.dark:text-gray-300.text-sm.px-3.py-1.5.rounded-full.hover:bg-gray-300.dark:hover:bg-gray-600.transition{type: "button", "data-action" => "click->comment-edit#cancelEdit"}
              Cancel

    / REPLY BUTTON
    - if current_user != comment.user
      .flex.items-center.gap-1.mt-1.ml-1
        %button.flex.items-center.gap-1.text-xs.font-semibold.text-gray-500.dark:text-gray-400.hover:text-blue-500.dark:hover:text-blue-400.transition-colors{type: "button", onclick: "document.getElementById('reply_form_#{comment.id}').classList.toggle('hidden')"}
          %svg.w-3.5.h-3.5{fill: "none", stroke: "currentColor", "stroke-width" => "2.5", viewbox: "0 0 24 24"}
            %path{d: "M3 10h10a8 8 0 018 8v2M3 10l6 6m-6-6l6-6", "stroke-linecap" => "round", "stroke-linejoin" => "round"}
          Reply

    / REPLY FORM
    - if current_user != comment.user
      .hidden.mt-2{id: "reply_form_#{comment.id}"}
        .flex.items-start.gap-2
          .w-7.h-7.rounded-full.overflow-hidden.bg-blue-600.flex.items-center.justify-center.shrink-0
            - if current_user.avatar.attached?
              = image_tag url_for(current_user.avatar), class: "w-full h-full object-cover"
            - else
              %span.text-white.text-xs.font-bold= current_user.email[0].upcase
          = form_with url: blog_comments_path(blog), scope: :comment, data: { turbo_stream: true }, class: "flex-1 flex gap-2" do |f|
            = f.hidden_field :parent_id, value: comment.id
            = f.text_field :body, placeholder: "Write a reply...", class: "flex-1 border border-gray-300 dark:border-gray-600 bg-gray-100 dark:bg-gray-700 text-gray-900 dark:text-white placeholder-gray-400 dark:placeholder-gray-500 rounded-full px-4 py-1.5 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500"
            = f.submit "Reply", class: "bg-blue-600 text-white text-sm px-4 py-1.5 rounded-full hover:bg-blue-700 transition cursor-pointer"

    / REPLIES LIST
    - if comment.parent_id.nil?
      .mt-3.ml-2.pl-4.border-l-2.border-gray-200.dark:border-gray-600.space-y-3{id: "replies_#{comment.id}"}
        - if comment.replies.any?
          = render comment.replies.order(created_at: :asc), blog: blog, current_user: current_user