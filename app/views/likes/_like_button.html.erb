<div id="like_button_blog_<%= blog.id %>">
  <% if current_user&.liked?(blog) %>
    <%= button_to blog_like_path(blog, current_user.likes.find_by(blog: blog)),
        method: :delete,
        class: "flex items-center gap-2 px-3 py-1.5 rounded-full bg-red-50 border border-red-200 hover:bg-red-100 transition-all duration-150 cursor-pointer" do %>
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24"
           style="fill:#ef4444; filter: drop-shadow(0 1px 2px rgba(239,68,68,0.4));">
        <path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5
                 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09
                 C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5
                 c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/>
      </svg>
      <span style="color:#ef4444; font-weight:600; font-size:14px;"><%= blog.likes.count %></span>
    <% end %>
  <% else %>
    <%= button_to blog_likes_path(blog),
        method: :post,
        class: "flex items-center gap-2 px-3 py-1.5 rounded-full bg-gray-100 border border-gray-200 hover:bg-red-50 hover:border-red-200 transition-all duration-150 cursor-pointer group" do %>
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24"
           style="fill:none; stroke:#9ca3af; stroke-width:2; stroke-linecap:round; stroke-linejoin:round;">
        <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06
                 a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78
                 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
      </svg>
      <span style="color:#6b7280; font-weight:500; font-size:14px;"><%= blog.likes.count %></span>
    <% end %>
  <% end %>
</div>