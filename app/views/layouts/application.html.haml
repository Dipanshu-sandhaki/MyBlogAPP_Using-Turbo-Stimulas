%html
  %head
    %meta{content: "text/html; charset=UTF-8", "http-equiv" => "Content-Type"}/
    %title TurboBlog
    :javascript
      if (localStorage.getItem("theme") === "dark") {
        document.documentElement.classList.add("dark")
      }
    %meta{content: "width=device-width,initial-scale=1", name: "viewport"}/
    = csrf_meta_tags
    = csp_meta_tag
    %link{href: "https://cdnjs.cloudflare.com/ajax/libs/flowbite/2.3.0/flowbite.min.css", rel: "stylesheet"}/
    = stylesheet_link_tag "tailwind", "data-turbo-track": "reload", preload: false
    = stylesheet_link_tag "actiontext", "data-turbo-track": "reload", preload: false
    = stylesheet_link_tag "blog_editor", "data-turbo-track": "reload", preload: false
    = javascript_importmap_tags
    :css
      .custom-scrollbar { scrollbar-width: none; }
      .custom-scrollbar:hover { scrollbar-width: thin; scrollbar-color: #cbd5e1 transparent; }
      .dark .custom-scrollbar:hover { scrollbar-color: #475569 transparent; }
      .custom-scrollbar::-webkit-scrollbar { width: 6px; }
      .custom-scrollbar::-webkit-scrollbar-track { background: transparent; }
      .custom-scrollbar::-webkit-scrollbar-thumb { background-color: transparent; border-radius: 20px; transition: background-color 0.3s ease; }
      .custom-scrollbar:hover::-webkit-scrollbar-thumb { background-color: #cbd5e1; }
      .dark .custom-scrollbar:hover::-webkit-scrollbar-thumb { background-color: #475569; }

      .badge-published { background: #eef2ff; color: #4338ca; border: 1px solid #c7d2fe; }
      .dark .badge-published { background: #1e1b4b; color: #a5b4fc; border-color: #3730a3; }
      .badge-saved { background: #ecfdf5; color: #047857; border: 1px solid #a7f3d0; }
      .dark .badge-saved { background: #022c22; color: #6ee7b7; border-color: #065f46; }
      .badge-draft { background: #fffbeb; color: #b45309; border: 1px solid #fde68a; }
      .dark .badge-draft { background: #1c1400; color: #fbbf24; border-color: #92400e; }

      .role-badge-viewer { background-color: #f3f4f6; color: #374151; border: 1px solid #d1d5db; }
      .role-badge-writer { background-color: #dbeafe; color: #1d4ed8; border: 1px solid #93c5fd; }
      .role-badge-admin { background-color: #f3e8ff; color: #7e22ce; border: 1px solid #d8b4fe; }

      html.dark .role-badge-viewer { background-color: #374151; color: #e5e7eb; border-color: #4b5563; }
      html.dark .role-badge-writer { background-color: #1e3a5f; color: #93c5fd; border-color: #2563eb; }
      html.dark .role-badge-admin { background-color: #3b1a5e; color: #d8b4fe; border-color: #7c3aed; }

      html.dark body { background-color: #030712; }

  %body.page-wrapper.bg-gray-100.dark:bg-gray-950.min-h-screen.flex.flex-col.transition-colors.duration-300{"data-controller" => "modal darkmode"}
    %nav.bg-white.dark:bg-gray-800.border-b.border-gray-200.dark:border-gray-800.px-6.py-3.flex.items-center.justify-between.sticky.top-0.z-50.shadow-sm.dark:shadow-md{class: "dark:shadow-black/30"}
      = link_to "TurboBlog", root_path, class: "text-blue-600 dark:text-blue-400 font-extrabold text-xl tracking-tight"

      .flex.items-center.gap-3
        - if can?(:create, Blog)
          = link_to dashboard_path, class: "hidden sm:flex items-center gap-1.5 px-4 py-1.5 rounded-full bg-blue-50 hover:bg-blue-100 dark:bg-blue-600 dark:hover:bg-blue-500 text-blue-600 dark:text-white text-sm font-bold transition-all border border-blue-100 dark:border-blue-500" do
            = raw('<svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/></svg>')
            Dashboard

        %button.p-2.rounded-full.bg-gray-100.dark:bg-gray-800.hover:bg-gray-200.dark:hover:bg-gray-700.transition-all.duration-200.border.border-gray-200.dark:border-gray-700{"data-action" => "click->darkmode#toggle", title: "Toggle dark mode"}
          = raw('<svg class="w-4 h-4 text-gray-600 block dark:hidden" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M21 12.79A9 9 0 1111.21 3 7 7 0 0021 12.79z"/></svg>')
          = raw('<svg class="w-4 h-4 text-yellow-400 hidden dark:block" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364-6.364l-.707.707M6.343 17.657l-.707.707m12.728 0l-.707-.707M6.343 6.343l-.707-.707M16 12a4 4 0 11-8 0 4 4 0 018 0z"/></svg>')

        - if user_signed_in?
          .relative{"data-controller" => "dropdown"}
            %button.flex.items-center.justify-center.w-9.h-9.rounded-full.overflow-hidden.border-2.border-blue-500.hover:border-blue-400.transition.focus:outline-none{"data-action" => "click->dropdown#toggle click@window->dropdown#hide"}
              - if current_user.avatar.attached?
                = image_tag url_for(current_user.avatar), class: "w-full h-full object-cover"
              - else
                .w-full.h-full.bg-blue-600.flex.items-center.justify-center
                  %span.text-white.text-sm.font-bold= current_user.email[0].upcase

            .hidden.absolute.right-0.mt-2.w-56.bg-white.dark:bg-gray-800.rounded-xl.shadow-2xl.border.border-gray-200.dark:border-gray-700.py-2.z-50{"data-dropdown-target" => "menu"}
              .px-4.py-3.border-b.border-gray-100.dark:border-gray-700
                %p.text-xs.text-gray-400.dark:text-gray-500.font-medium Signed in as
                %p.text-sm.text-gray-800.dark:text-gray-200.font-semibold.truncate= current_user.email
                - role_badge_class = case current_user.role
                  - when "admin"  then "role-badge-admin"
                  - when "writer" then "role-badge-writer"
                  - else               "role-badge-viewer"
                - role_label = current_user.role&.capitalize || "Viewer"
                %span{class: "mt-1.5 inline-block text-xs font-bold px-2.5 py-0.5 rounded-full #{role_badge_class}"}
                  = role_label

              - if can?(:create, Blog)
                = link_to my_blogs_path, class: "flex items-center gap-2 px-4 py-2 text-sm text-gray-700 dark:text-gray-300 hover:bg-gray-100 dark:hover:bg-gray-700 transition" do
                  = raw('<svg class="w-4 h-4 text-gray-500 dark:text-gray-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10l6 6v10a2 2 0 01-2 2z"/></svg>')
                  My Blogs

                = link_to drafts_path, class: "flex items-center gap-2 px-4 py-2 text-sm text-gray-700 dark:text-gray-300 hover:bg-gray-100 dark:hover:bg-gray-700 transition" do
                  = raw('<svg class="w-4 h-4 text-gray-500 dark:text-gray-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>')
                  Drafts
                  - draft_count = current_user.blogs.draft.count
                  - if draft_count > 0
                    %span.ml-auto.inline-flex.items-center.justify-center.w-5.h-5.rounded-full.text-xs.bg-gray-200.text-gray-600.dark:bg-gray-600.dark:text-gray-300= draft_count

              = link_to edit_profile_path, class: "flex items-center gap-2 px-4 py-2 text-sm text-gray-700 dark:text-gray-300 hover:bg-gray-100 dark:hover:bg-gray-700 transition" do
                = raw('<svg class="w-4 h-4 text-gray-500 dark:text-gray-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>')
                Edit Profile

              = button_to destroy_user_session_path, method: :delete, class: "w-full flex items-center gap-2 px-4 py-2 text-sm text-red-500 dark:text-red-400 hover:bg-red-50 dark:hover:bg-gray-700 transition text-left border-t border-gray-100 dark:border-gray-700 mt-1" do
                = raw('<svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a2 2 0 01-2 2H6a2 2 0 01-2-2V7a2 2 0 012-2h5a2 2 0 012 2v1"/></svg>')
                Logout

    #flash= render "shared/flash"
    .flex-1= yield

    %footer.bg-white.dark:bg-gray-800.border-t.border-gray-200.dark:border-gray-800.mt-auto.shadow-sm.dark:shadow-md{class: "dark:shadow-black/30"}
      .max-w-5xl.mx-auto.px-6.py-8
        .flex.flex-col.sm:flex-row.items-center.sm:items-start.justify-between.gap-6.mb-6
          .flex.flex-col.items-center.sm:items-start.gap-1
            = link_to root_path, class: "text-blue-600 dark:text-blue-400 font-extrabold text-xl tracking-tight hover:opacity-80 transition-opacity" do
              TurboBlog
            %span.text-gray-500.dark:text-gray-400.text-xs.font-medium.tracking-widest.uppercase
              Write. Share. Connect.

          .flex.flex-wrap.items-center.justify-center.gap-5
            = link_to "Feed", root_path, class: "text-sm font-semibold text-gray-600 dark:text-gray-300 hover:text-blue-600 dark:hover:text-blue-400 transition-all duration-150"
            - if can?(:create, Blog)
              = link_to "My Blogs", my_blogs_path, class: "text-sm font-semibold text-gray-600 dark:text-gray-300 hover:text-blue-600 dark:hover:text-blue-400 transition-all duration-150"
            - if user_signed_in?
              = link_to "Edit Profile", edit_profile_path, class: "text-sm font-semibold text-gray-600 dark:text-gray-300 hover:text-blue-600 dark:hover:text-blue-400 transition-all duration-150"
              = link_to "Security", edit_user_registration_path, class: "text-sm font-semibold text-gray-600 dark:text-gray-300 hover:text-blue-600 dark:hover:text-blue-400 transition-all duration-150"

        .w-full.h-px.bg-gradient-to-r.from-transparent.via-gray-200.dark:via-gray-600.to-transparent.mb-5
        .flex.justify-center
          %p.text-xs.text-gray-500.dark:text-gray-400.font-medium.text-center
            © #{Time.current.year}
            %span.text-gray-500.dark:text-gray-400.font-semibold TurboBlog.
            All rights reserved.

    %script{src: "https://cdnjs.cloudflare.com/ajax/libs/flowbite/2.3.0/flowbite.min.js"}
    :javascript
      document.addEventListener("trix-before-initialize", () => {
        Trix.config.textAttributes.foregroundColor = { styleProperty: "color", inheritable: true }
        Trix.config.textAttributes.customFontSize = { styleProperty: "fontSize", inheritable: true }
      })