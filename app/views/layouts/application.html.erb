<!DOCTYPE html>
<html>
  <head>
    <title>TurboBlog</title>
    <script>
      if (localStorage.getItem("theme") === "dark") {
        document.documentElement.classList.add("dark")
      }
    </script>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/flowbite/2.3.0/flowbite.min.css" rel="stylesheet" />
    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "actiontext", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "blog_editor", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="page-wrapper bg-gray-100 min-h-screen flex flex-col"
      data-controller="modal darkmode">

    <!-- NAVBAR -->
    <nav class="bg-gray-800 px-6 py-3 flex items-center justify-between sticky top-0 z-50 shadow-md shadow-black/30">

      <%= link_to "TurboBlog", root_path, class: "text-blue-400 font-bold text-xl tracking-tight" %>

      <div class="flex items-center gap-3">

        <!-- DARK MODE TOGGLE -->
        <button data-action="click->darkmode#toggle"
                class="p-2 rounded-full bg-gray-800 hover:bg-gray-700 transition-all duration-200 border border-gray-700"
                title="Toggle dark mode">
          <!-- Moon — shown in light mode -->
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-gray-300 block dark:hidden" fill="none"
               viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round"
              d="M21 12.79A9 9 0 1111.21 3 7 7 0 0021 12.79z"/>
          </svg>
          <!-- Sun — shown in dark mode -->
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-yellow-400 hidden dark:block" fill="none"
               viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round"
              d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364-6.364l-.707.707
                 M6.343 17.657l-.707.707m12.728 0l-.707-.707M6.343 6.343l-.707-.707
                 M16 12a4 4 0 11-8 0 4 4 0 018 0z"/>
          </svg>
        </button>

        <% if user_signed_in? %>
          <div class="relative" data-controller="dropdown">
            <button data-action="click->dropdown#toggle click@window->dropdown#hide"
                    class="flex items-center justify-center w-9 h-9 rounded-full overflow-hidden
                           border-2 border-blue-500 hover:border-blue-400 transition focus:outline-none">
              <% if current_user.avatar.attached? %>
                <%= image_tag url_for(current_user.avatar), class: "w-full h-full object-cover" %>
              <% else %>
                <div class="w-full h-full bg-blue-600 flex items-center justify-center">
                  <span class="text-white text-sm font-bold"><%= current_user.email[0].upcase %></span>
                </div>
              <% end %>
            </button>

            <div data-dropdown-target="menu"
                 class="hidden absolute right-0 mt-2 w-56 bg-gray-800 rounded-xl
                        shadow-2xl border border-gray-700 py-2 z-50">
              <div class="px-4 py-2 border-b border-gray-700">
                <p class="text-xs text-gray-500 font-medium">Signed in as</p>
                <p class="text-sm text-gray-200 font-semibold truncate"><%= current_user.email %></p>
              </div>
              <%= link_to my_blogs_path,
                  class: "flex items-center gap-2 px-4 py-2 text-sm text-gray-300 hover:bg-gray-700 transition" do %>
                <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-gray-400" fill="none"
                     viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                    d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10l6 6v10a2 2 0 01-2 2z"/>
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 2v6h6"/>
                </svg>
                My Blogs
              <% end %>
              <%= link_to edit_user_registration_path,
                  class: "flex items-center gap-2 px-4 py-2 text-sm text-gray-300 hover:bg-gray-700 transition" do %>
                <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-gray-400" fill="none"
                     viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                    d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
                </svg>
                Edit Profile
              <% end %>
              <%= button_to destroy_user_session_path, method: :delete,
                  class: "w-full flex items-center gap-2 px-4 py-2 text-sm text-red-400 hover:bg-gray-700 transition text-left" do %>
                <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none"
                     viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                    d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a2 2 0 01-2 2H6a2 2 0 01-2-2V7a2 2 0 012-2h5a2 2 0 012 2v1" />
                </svg>
                Logout
              <% end %>
            </div>
          </div>
        <% end %>
      </div>
    </nav>

    <div id="flash"><%= render "shared/flash" %></div>
    <div class="flex-1"><%= yield %></div>

    <!-- GLOBAL MODAL -->
    <div data-modal-target="modal"
         data-action="click->modal#backdropClose"
         class="hidden fixed inset-0 z-[9999] flex items-center justify-center
                bg-black/90 backdrop-blur-md transition-all duration-200">
      <div class="w-full max-w-2xl px-4">
        <div class="bg-white dark:bg-gray-900 rounded-2xl shadow-[0_30px_80px_rgba(0,0,0,0.5)]
                    border border-gray-300 dark:border-gray-700 overflow-hidden">
          <turbo-frame id="modal"></turbo-frame>
        </div>
      </div>
    </div>

    <!-- DELETE MODAL -->
    <div data-modal-target="deleteModal"
         data-action="click->modal#backdropClose"
         class="hidden fixed inset-0 z-[9999] flex items-center justify-center
                bg-black/80 backdrop-blur-sm">
      <div class="relative p-4 w-full max-w-md">
        <div class="relative bg-gray-900 rounded-xl shadow-2xl border border-gray-700 p-6 text-center">
          <div class="flex justify-center mb-4">
            <div class="w-12 h-12 flex items-center justify-center rounded-full bg-red-900/50">
              <svg class="w-6 h-6 text-red-400" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                <path stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
                  d="M12 9v3m0 3h.01M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z"/>
              </svg>
            </div>
          </div>
          <h3 class="text-lg font-semibold text-gray-100 mb-2">Delete Blog?</h3>
          <p class="text-sm text-gray-400 mb-6">Are you sure you want to delete this Blog?</p>
          <div class="flex justify-center gap-3">
            <button type="button" data-action="click->modal#closeDelete"
                    class="px-4 py-2 text-sm font-medium text-gray-300 bg-gray-700 rounded-lg hover:bg-gray-600 transition">
              Cancel
            </button>
            <button type="button" data-action="click->modal#confirmDelete"
                    class="px-4 py-2 text-sm font-medium text-white bg-red-600 rounded-lg hover:bg-red-700 shadow-sm transition">
              Yes, Delete
            </button>
          </div>
        </div>
      </div>
    </div>

    <!-- FOOTER -->
    <footer class="bg-gray-800 px-6 py-3 mt-auto shadow-md shadow-black/30">
      <div class="max-w-5xl mx-auto px-6 py-8">
        <div class="flex flex-col md:flex-row items-center justify-between gap-4">
          <div>
            <p class="text-blue-400 font-bold text-lg">TurboBlog</p>
            <p class="text-gray-400 text-xs mt-0.5">Write. Share. Connect.</p>
          </div>
          <div class="flex items-center gap-6 text-sm text-gray-400">
            <%= link_to "Feed", root_path, class: "hover:text-blue-400 transition" %>
            <% if user_signed_in? %>
              <%= link_to "My Blogs", my_blogs_path, class: "hover:text-blue-400 transition" %>
              <%= link_to "Edit Profile", edit_user_registration_path, class: "hover:text-blue-400 transition" %>
            <% end %>
          </div>
          <p class="text-gray-400 text-xs">© <%= Time.current.year %> TurboBlog. All rights reserved.</p>
        </div>
      </div>
    </footer>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/flowbite/2.3.0/flowbite.min.js"></script>
    <script>
  document.addEventListener("trix-before-initialize", () => {
    // Allow custom inline styles to be preserved in ActionText HTML
    Trix.config.textAttributes.foregroundColor = {
      styleProperty: "color",
      inheritable: true
    }
    Trix.config.textAttributes.customFontSize = {
      styleProperty: "fontSize",
      inheritable: true
    }
  })
</script>
  </body>
</html>