<!DOCTYPE html>
<html>
  <head>
    <title>TurboBlog</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">

    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <!-- Flowbite -->
    <link href="https://cdnjs.cloudflare.com/ajax/libs/flowbite/2.3.0/flowbite.min.css" rel="stylesheet" />

    <!-- Tailwind -->
    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>

    <!-- JS -->
    <%= javascript_importmap_tags %>
  </head>

  <body class="bg-gray-100 min-h-screen" data-controller="modal">

    <% if user_signed_in? %>
      <nav class="bg-white border-b border-gray-200 shadow-sm">
        <div class="max-w-4xl mx-auto flex justify-between items-center p-4">

          <h1 class="text-xl font-bold text-blue-600">TurboBlog</h1>

          <div class="flex items-center gap-3">
            <span class="text-gray-600 text-sm">
              <%= current_user.email %>
            </span>

            <%= button_to "Logout",
              destroy_user_session_path,
              method: :delete,
              class: "text-white bg-red-500 hover:bg-red-600 px-4 py-2 rounded-lg text-sm" %>
          </div>

        </div>
      </nav>
    <% end %>

    <!-- PAGE CONTENT -->
    <div class="max-w-3xl mx-auto mt-10">
      <%= yield %>
    </div>

    <!-- ================= GLOBAL MODAL ================= -->
    <div
      data-modal-target="modal"
      data-action="click->modal#backdropClose"
      class="hidden fixed inset-0 z-[9999] flex items-center justify-center
             bg-black/90 backdrop-blur-md transition-all duration-200">

      <div class="w-full max-w-2xl px-4">

        <!-- MODAL CARD -->
        <div class="bg-white rounded-2xl
                    shadow-[0_30px_80px_rgba(0,0,0,0.5)]
                    border border-gray-300
                    overflow-hidden">

          <turbo-frame id="modal"></turbo-frame>

        </div>

      </div>
    </div>

    <!-- ================= DELETE MODAL ================= -->
<div
  data-modal-target="deleteModal"
  data-action="click->modal#backdropClose"
  class="hidden fixed inset-0 z-[9999] flex items-center justify-center
         bg-black/80 backdrop-blur-sm">

  <div class="relative p-4 w-full max-w-md">

    <div class="relative bg-white rounded-xl shadow-2xl border border-gray-200 p-6 text-center">

      <!-- ICON -->
      <div class="flex justify-center mb-4">
        <div class="w-12 h-12 flex items-center justify-center rounded-full bg-red-100">
          <svg class="w-6 h-6 text-red-600" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
            <path stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
              d="M12 9v3m0 3h.01M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z"/>
          </svg>
        </div>
      </div>

      <!-- TEXT -->
      <h3 class="text-lg font-semibold text-gray-900 mb-2">
        Delete Blog?
      </h3>

      <p class="text-sm text-gray-500 mb-6">
        Are you sure? you want to delete this Blog
      </p>

      <!-- ACTIONS -->
      <div class="flex justify-center gap-3">

        <!-- CANCEL -->
        <button
          type="button"
          data-action="click->modal#closeDelete"
          class="px-4 py-2 text-sm font-medium text-gray-700 bg-gray-100 rounded-lg
                 hover:bg-gray-200 transition">
          Cancel
        </button>

        <!-- DELETE -->
        <button
          type="button"
          data-action="click->modal#confirmDelete"
          class="px-4 py-2 text-sm font-medium text-white bg-red-600 rounded-lg
                 hover:bg-red-700 shadow-sm transition">
          Yes, Delete
        </button>

      </div>

    </div>
  </div>
</div>

    <!-- Flowbite JS -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/flowbite/2.3.0/flowbite.min.js"></script>

  </body>
</html>